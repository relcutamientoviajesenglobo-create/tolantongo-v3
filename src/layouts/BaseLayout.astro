---
import { languages } from '../i18n/config';
import type { Lang } from '../i18n/config';
import { t } from '../i18n/utils';
import { getHreflangs } from '../i18n/routes';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  breadcrumbs?: {label: string; href?: string}[];
  lang?: Lang;
}

const {
  title,
  description,
  canonical,
  ogImage = '/media/grutas-tolantongo-pozas-termales-panoramica-amplia.webp',
  schema,
  breadcrumbs,
} = Astro.props;

const lang: Lang = Astro.props.lang || 'es';
const langConfig = languages[lang];
const hreflangs = getHreflangs(Astro.url.pathname, lang);

const siteUrl = 'https://tolantongo.com.mx';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const schemaArr = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!DOCTYPE html>
<html lang={langConfig.locale}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>
  <link rel="alternate" hreflang="es" href={`${siteUrl}${hreflangs.es}`} />
  <link rel="alternate" hreflang="en" href={`${siteUrl}${hreflangs.en}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${hreflangs.es}`} />
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={`${siteUrl}${ogImage}`}>
  <meta property="og:locale" content={langConfig.ogLocale}>
  <meta property="og:site_name" content="Grutas de Tolantongo">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`}>
  <!-- Fonts: self-hosted Savior Sans Expanded (headings) + Lexend (body/UI) -->
  <!-- Preload critical fonts for fastest render -->
  <link rel="preload" href="/fonts/SaviorSans-ExpandedExtrabold.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/lexend-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/lexend-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin>
  <!-- Google Fonts fallback: Barlow Condensed (proxy si Savior Sans falla) + Lexend (redundancia CDN) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;700&family=Barlow+Condensed:wght@800&display=swap" rel="stylesheet">
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <!-- Schema.org JSON-LD -->
  {schemaArr.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(schemaArr)} />
  )}
  <meta name="theme-color" content="#FEC700">
</head>
<body>
  <a class="skip-link" href="#main-content">{t('skip-link', lang)}</a>
  <slot name="header" />
  <main id="main-content">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <div class="breadcrumbs">
        <div class="container">
          <ol class="breadcrumbs__list" itemscope itemtype="https://schema.org/BreadcrumbList">
            <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href={lang === 'en' ? '/en/' : '/'} class="breadcrumbs__link" itemprop="item"><span itemprop="name">{t('breadcrumb.home', lang)}</span></a>
              <meta itemprop="position" content="1">
            </li>
            {breadcrumbs.map((crumb, i) => (
              <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <span class="breadcrumbs__sep">&rsaquo;</span>
                {crumb.href
                  ? <a href={crumb.href} class="breadcrumbs__link" itemprop="item"><span itemprop="name">{crumb.label}</span></a>
                  : <span class="breadcrumbs__current" itemprop="name">{crumb.label}</span>
                }
                <meta itemprop="position" content={String(i + 2)}>
              </li>
            ))}
          </ol>
        </div>
      </div>
    )}
    <slot />
  </main>
  <slot name="footer" />
  <!-- WhatsApp FAB -->
  <a href={`https://wa.me/525564650507?text=${t('whatsapp.msg', lang)}`}
     class="whatsapp-fab"
     aria-label={t('whatsapp.aria', lang)}
     target="_blank"
     rel="noopener noreferrer">
    <span class="whatsapp-fab__pulse"></span>
    <span class="whatsapp-fab__icon">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" fill="white"/>
      </svg>
    </span>
    <span class="whatsapp-fab__label">{t('whatsapp.label', lang)}</span>
  </a>

  <!-- Back to Top Button -->
  <button class="back-to-top" id="back-to-top" aria-label={t('back-to-top', lang)}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>

  <!-- Scroll-triggered animations + Back to top -->
  <script>
    // Intersection Observer for scroll-triggered entrance animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));

    // Back to top button
    const backToTopBtn = document.getElementById('back-to-top');
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          if (window.scrollY > 400) {
            backToTopBtn?.classList.add('is-visible');
          } else {
            backToTopBtn?.classList.remove('is-visible');
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    backToTopBtn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
