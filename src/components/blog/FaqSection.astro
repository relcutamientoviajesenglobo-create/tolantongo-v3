---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

export interface Props {
  faqs: { q: string; a: string }[];
  title?: string;
  lang?: Lang;
}

const lang: Lang = Astro.props.lang || 'es';
const { faqs, title = t('blog.faq.title', lang) } = Astro.props;
---

{faqs.length > 0 && (
  <section class="faq-section">
    <h2>{title}</h2>
    <div class="faq-list">
      {faqs.map((faq, i) => (
        <details class="faq-item" id={`faq-${i}`}>
          <summary class="faq-item__question">
            <span>{faq.q}</span>
            <svg class="faq-item__chevron" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </summary>
          <div class="faq-item__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </section>
)}
