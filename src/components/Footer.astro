---

<footer class="footer" role="contentinfo">

  <!-- CTA BANNER (MC style) -->
  <div class="footer__cta">
    <div style="position:absolute;top:0;right:0;opacity:.12;pointer-events:none;color:#FEC700">
      <Fragment set:html={DAFF_LARGE} />
    </div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.1;pointer-events:none;color:#FEC700;transform:rotate(180deg)">
      <Fragment set:html={DAFF_LARGE} />
    </div>
    <div class="container">
      <h2>{t('footer.cta.title', lang)}</h2>
      <p>{t('footer.cta.desc', lang)}</p>
      <div class="footer__cta-actions">
        <a href={href('/precios/')} class="btn btn--primary btn--lg">{t('footer.cta.prices', lang)}</a>
        <a href={href('/como-llegar/')} class="btn btn--outline btn--lg">{t('footer.cta.directions', lang)}</a>
      </div>
    </div>
  </div>

