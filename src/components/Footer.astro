---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/config';
import { getAlternatePath } from '../i18n/routes';
import LanguageSelector from './LanguageSelector.astro';

interface Props {
  lang?: Lang;
}

const lang: Lang = Astro.props.lang || 'es';

/** Return the localized href for a given Spanish path */
function href(esPath: string): string {
  if (lang === 'en') {
    return getAlternatePath(esPath, 'es');
  }
  return esPath;
}

