---
import { getNavItems } from '../i18n/nav';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/config';

interface Props {
  lang?: Lang;
}

const lang: Lang = Astro.props.lang || 'es';
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
const navItems = getNavItems(lang);
const pricesHref = lang === 'en' ? '/en/prices/' : '/precios/';
---

<header class="header" role="banner">
  <div class="container header__inner">

    <!-- LOGO -->
    <a href={lang === 'en' ? '/en/' : '/'} class="header__logo" aria-label="Grutas de Tolantongo — Inicio">
      <svg class="logo__mark" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="28" cy="28" r="28" fill="#1951A0"/>
        <g transform="translate(5,7) scale(0.192)">
          <path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="#FEC700"/>
          <ellipse cx="84" cy="105" rx="28" ry="18" fill="#E8A800" opacity="0.55"/>
          <ellipse cx="84" cy="105" rx="16" ry="11" fill="#FEC700" opacity="0.9"/>
        </g>
      </svg>
      <div class="logo__text">
        <span class="logo__name">Tolantongo</span>
        <span class="logo__sub">Grutas Termales · Hidalgo</span>
        <span class="logo__loc">Cardonal, México</span>
      </div>
    </a>

    <!-- TELÉFONO (desktop) -->
    <a href="tel:+525564650507" class="header__phone">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.62 10.79z"/>
      </svg>
      <span>+52 55 6465 0507</span>
    </a>

    <!-- NAV DESKTOP -->
    <nav class="nav" aria-label={t('nav.aria', lang)}>
      <ul class="nav__list">
        {navItems.map(item => (
          <li class={`nav__item ${item.children ? 'nav__item--dropdown' : ''}`}>
            <a href={item.href} class={`nav__link ${isActive(item.href) ? 'active' : ''}`}>
              {item.label}
              {item.children && (
                <svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="3 6 8 11 13 6"/>
                </svg>
              )}
            </a>
            {item.children && (
              <ul class="dropdown" role="list">
                {item.children.map(child => (
                  <li>
                    <a href={child.href} class="dropdown__link">
                      <svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="5 3 10 8 5 13"/>
                      </svg>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA DESKTOP -->
    <div class="header__cta">
      <a href={pricesHref} class="btn btn--primary btn--sm">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true">
          <path d="M22 10V6c0-1.11-.9-2-2-2H4c-1.1 0-1.99.89-1.99 2v4c1.1 0 1.99.9 1.99 2s-.89 2-1.99 2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-4c-1.1 0-2-.9-2-2s.9-2 2-2zm-2-1.46c-1.19.69-2 1.99-2 3.46s.81 2.77 2 3.46V18H4v-2.54c1.19-.69 2-1.99 2-3.46 0-1.48-.8-2.77-2-3.46V6h16v2.54z"/>
        </svg>
        {t('nav.cta', lang)}
      </a>
    </div>

    <!-- HAMBURGER MOBILE -->
    <button class="header__burger" id="mobile-menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label={t('nav.burger.open', lang)}>
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- MOBILE NAV OVERLAY -->
  <div class="mobile-nav-overlay" id="mobile-nav-overlay"></div>

  <!-- MOBILE NAV -->
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <!-- Close button -->
    <button class="mobile-nav__close" id="mobile-nav-close" aria-label={t('nav.burger.close', lang)}>
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <nav aria-label={t('nav.mobile.aria', lang)}>
      <ul>
        {navItems.map(item => (
          <li>
            {item.children ? (
              <div class="mobile-nav__link-row">
                <a href={item.href} class="mobile-nav__link">{item.label}</a>
                <button class="mobile-nav__toggle" aria-expanded="false" aria-label={`${t('nav.expand', lang)} ${item.label}`}>
                  <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="4 6 8 10 12 6"/>
                  </svg>
                </button>
              </div>
            ) : (
              <a href={item.href} class="mobile-nav__link">{item.label}</a>
            )}
            {item.children && (
              <ul class="mobile-nav__sub">
                {item.children.map(child => (
                  <li><a href={child.href} class="mobile-nav__sublink">{child.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <div class="mobile-nav__cta">
        <a href={pricesHref} class="btn btn--primary" style="width:100%;justify-content:center;">
          {t('nav.cta.mobile', lang)}
        </a>
      </div>
      <a href="tel:+525564650507" class="mobile-nav__phone">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.62 10.79z"/>
        </svg>
        +52 55 6465 0507
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle with body lock + overlay
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  const overlay = document.getElementById('mobile-nav-overlay');

  function toggleMenu(forceClose?: boolean) {
    const shouldClose = forceClose ?? nav?.classList.contains('is-open');
    if (shouldClose) {
      nav?.classList.remove('is-open');
      btn?.classList.remove('is-open');
      overlay?.classList.remove('is-open');
      document.body.classList.remove('menu-open');
      btn?.setAttribute('aria-expanded', 'false');
      nav?.setAttribute('aria-hidden', 'true');
    } else {
      nav?.classList.add('is-open');
      btn?.classList.add('is-open');
      overlay?.classList.add('is-open');
      document.body.classList.add('menu-open');
      btn?.setAttribute('aria-expanded', 'true');
      nav?.setAttribute('aria-hidden', 'false');
    }
  }

  btn?.addEventListener('click', () => toggleMenu());
  overlay?.addEventListener('click', () => toggleMenu(true));

  // Close button inside mobile nav
  const closeBtn = document.getElementById('mobile-nav-close');
  closeBtn?.addEventListener('click', () => toggleMenu(true));

  // Close menu on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && nav?.classList.contains('is-open')) {
      toggleMenu(true);
    }
  });

  // Mobile accordion toggles
  const toggleBtns = document.querySelectorAll('.mobile-nav__toggle');
  toggleBtns.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const sub = toggle.closest('li')?.querySelector('.mobile-nav__sub');
      const isOpen = toggle.classList.contains('is-open');

      // Close all other submenus first (only one open at a time)
      toggleBtns.forEach(otherBtn => {
        if (otherBtn !== toggle) {
          otherBtn.classList.remove('is-open');
          otherBtn.setAttribute('aria-expanded', 'false');
          otherBtn.closest('li')?.querySelector('.mobile-nav__sub')?.classList.remove('is-open');
        }
      });

      // Toggle this one
      if (isOpen) {
        toggle.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        sub?.classList.remove('is-open');
      } else {
        toggle.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');
        sub?.classList.add('is-open');
      }
    });
  });

  // Header scroll shadow
  const header = document.querySelector('.header');
  let scrollTicking = false;
  window.addEventListener('scroll', () => {
    if (!scrollTicking) {
      requestAnimationFrame(() => {
        if (window.scrollY > 10) {
          header?.classList.add('scrolled');
        } else {
          header?.classList.remove('scrolled');
        }
        scrollTicking = false;
      });
      scrollTicking = true;
    }
  }, { passive: true });
</script>
