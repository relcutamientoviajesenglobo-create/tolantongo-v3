        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-panoramica-nublada.webp" alt="Panorámica de las pozas termales en día nublado" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-panoramica-nublada-2.webp" alt="Pozas termales de Tolantongo con neblina entre las montañas" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-vista-alta-soleada.webp" alt="Vista alta y soleada de las pozas termales escalonadas" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-vista-general-canon.webp" alt="Vista general de las pozas termales dentro del cañón" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-cueva-termal-silueta-agua.webp" alt="Silueta reflejada en el agua de la cueva termal de Tolantongo" width="600" height="450" loading="lazy">
        </div>
      </div>
    </div>
  </section>
