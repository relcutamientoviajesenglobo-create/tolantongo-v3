---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.silo === 'grutas-termales' && p.data.lang === 'en')
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Thermal Grottoes of Tolantongo',
  description: 'Articles about the grottoes, terraced pools, the thermal river, the canyon, and the geology of Mexico\'s most stunning thermal destination.',
  url: 'https://tolantongo.com.mx/en/blog/thermal-grottoes/',
};

const breadcrumbs = [
  { label: 'Blog', href: '/en/blog/' },
  { label: 'Thermal Grottoes' },
];
---

<BaseLayout title="Thermal Grottoes of Tolantongo — Geology, Temperature & Nature" description="Everything about the thermal grottoes, terraced pools, thermal river, and the Tolantongo canyon. Geology, temperatures by zone, and natural wonders." canonical="/en/blog/thermal-grottoes/" schema={schema} breadcrumbs={breadcrumbs} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Topic: Thermal Grottoes</span>
        <h1 class="hero__title">Thermal Grottoes of Tolantongo</h1>
        <p class="hero__desc">Geology, temperatures, natural formations, and everything that makes this canyon a unique thermal phenomenon in Mexico.</p>
        <div class="hero__actions">
          <a href="/en/grottoes/" class="btn btn--primary btn--lg">Explore the Grottoes</a>
          <a href="/en/blog/travel-guides/" class="btn btn--outline btn--lg">Travel Guides</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-cueva-termal-visitantes.webp" alt="Inside the Grutas de Tolantongo with thermal steam" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Articles about the Thermal Grottoes</h2>
        <p>Explore the science, nature, and secrets behind one of the most spectacular thermal destinations in Latin America.</p>
      </div>
      {posts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug.replace(/^en-/, '')}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
              lang="en"
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Articles about the thermal grottoes coming soon. Stay tuned!</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>More Topics about Tolantongo</h2>
      </div>
      <div class="card-grid card-grid--3">
        <a href="/en/blog/travel-guides/" class="service-card">
          <div class="service-card__icon">{'\u{1F4CB}'}</div>
          <h3 class="service-card__title">Travel Guides</h3>
          <p class="service-card__desc">What to bring, how to get there, prices, and everything to plan your visit.</p>
        </a>
        <a href="/en/blog/adventure-activities/" class="service-card">
          <div class="service-card__icon">{'\u{1F9D7}'}</div>
          <h3 class="service-card__title">Activities & Adventure</h3>
          <p class="service-card__desc">Hiking, rappelling, thermal swimming, and photography.</p>
        </a>
        <a href="/en/blog/culture-region/" class="service-card">
          <div class="service-card__icon">{'\u{1F3DB}\uFE0F'}</div>
          <h3 class="service-card__title">Culture & Region</h3>
          <p class="service-card__desc">History, Hnahnu gastronomy, and Cardonal.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
