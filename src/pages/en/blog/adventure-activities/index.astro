---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.silo === 'actividades-aventura' && p.data.lang === 'en')
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Activities & Adventure in Tolantongo',
  description: 'Hiking guides, rappelling, thermal swimming, photography, and all the activities you can enjoy at Grutas de Tolantongo.',
  url: 'https://tolantongo.com.mx/en/blog/adventure-activities/',
};

const breadcrumbs = [
  { label: 'Blog', href: '/en/blog/' },
  { label: 'Activities & Adventure' },
];
---

<BaseLayout title="Activities & Adventure in Tolantongo — Hiking, Rappelling & More" description="Complete guides to hiking, rappelling, thermal swimming, photography, and all adventure activities at Grutas de Tolantongo." canonical="/en/blog/adventure-activities/" schema={schema} breadcrumbs={breadcrumbs} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Topic: Activities</span>
        <h1 class="hero__title">Activities & Adventure in Tolantongo</h1>
        <p class="hero__desc">Hiking, rappelling, thermal swimming, photography, and all the experiences you can enjoy in the most stunning canyon of Hidalgo.</p>
        <div class="hero__actions">
          <a href="/en/activities/" class="btn btn--primary btn--lg">See Activities</a>
          <a href="/en/blog/travel-guides/" class="btn btn--outline btn--lg">Travel Guides</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-cascada-sendero-visitante.webp" alt="Hiking in the Tolantongo Canyon" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Activities & Adventure Articles</h2>
        <p>Detailed guides for every activity, written by certified local guides who know the terrain.</p>
      </div>
      {posts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug.replace(/^en-/, '')}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
              lang="en"
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Activity guides coming soon. Stay tuned!</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Explore More Topics</h2>
      </div>
      <div class="card-grid card-grid--3">
        <a href="/en/blog/thermal-grottoes/" class="service-card">
          <div class="service-card__icon">{'\u{1F30A}'}</div>
          <h3 class="service-card__title">Thermal Grottoes</h3>
          <p class="service-card__desc">Geology, temperatures, and natural formations.</p>
        </a>
        <a href="/en/blog/lodging-camping/" class="service-card">
          <div class="service-card__icon">{'\u{1F3D5}\uFE0F'}</div>
          <h3 class="service-card__title">Lodging & Camping</h3>
          <p class="service-card__desc">Cabins, campsite, and where to stay.</p>
        </a>
        <a href="/en/blog/travel-guides/" class="service-card">
          <div class="service-card__icon">{'\u{1F4CB}'}</div>
          <h3 class="service-card__title">Travel Guides</h3>
          <p class="service-card__desc">What to bring, how to get there, prices, and more.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
