---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.silo === 'cultura-region' && p.data.lang === 'en')
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Culture & Region of Tolantongo',
  description: 'History, Hnahnu culture, regional gastronomy, and sustainable tourism in Cardonal and the Sierra Gorda of Hidalgo.',
  url: 'https://tolantongo.com.mx/en/blog/culture-region/',
};

const breadcrumbs = [
  { label: 'Blog', href: '/en/blog/' },
  { label: 'Culture & Region' },
];
---

<BaseLayout title="Culture & Region — History, Gastronomy & Cardonal, Hidalgo" description="Discover the history of Grutas de Tolantongo, Hnahnu culture, Sierra Gorda gastronomy, and the municipality of Cardonal, Hidalgo." canonical="/en/blog/culture-region/" schema={schema} breadcrumbs={breadcrumbs} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Topic: Culture</span>
        <h1 class="hero__title">Culture & Region of Tolantongo</h1>
        <p class="hero__desc">The history, the Hnahnu culture, the Sierra Gorda gastronomy, and the context that makes Tolantongo much more than a thermal destination.</p>
        <div class="hero__actions">
          <a href="/en/blog/travel-guides/" class="btn btn--primary btn--lg">Travel Guides</a>
          <a href="/en/blog/" class="btn btn--outline btn--lg">All Blog Posts</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-atardecer-canon-hidalgo.webp" alt="View of Tolantongo Canyon in the Sierra Gorda of Hidalgo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>History, Culture & Region</h2>
        <p>Articles about the historical, cultural, and geographical context surrounding Grutas de Tolantongo.</p>
      </div>
      {posts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug.replace(/^en-/, '')}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
              lang="en"
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Culture and region articles coming soon. Stay tuned!</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Explore Other Topics</h2>
      </div>
      <div class="card-grid card-grid--3">
        <a href="/en/blog/thermal-grottoes/" class="service-card">
          <div class="service-card__icon">{'\u{1F30A}'}</div>
          <h3 class="service-card__title">Thermal Grottoes</h3>
          <p class="service-card__desc">Geology, temperatures, and the canyon's natural wonders.</p>
        </a>
        <a href="/en/blog/travel-guides/" class="service-card">
          <div class="service-card__icon">{'\u{1F4CB}'}</div>
          <h3 class="service-card__title">Travel Guides</h3>
          <p class="service-card__desc">Everything to plan your visit to Tolantongo.</p>
        </a>
        <a href="/en/blog/lodging-camping/" class="service-card">
          <div class="service-card__icon">{'\u{1F3D5}\uFE0F'}</div>
          <h3 class="service-card__title">Lodging & Camping</h3>
          <p class="service-card__desc">Cabins, campsite, and where to stay.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
