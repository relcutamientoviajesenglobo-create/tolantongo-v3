---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.silo === 'hospedaje-camping' && p.data.lang === 'en')
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Lodging & Camping in Tolantongo',
  description: 'Cabin guides, camping, reservations, and accommodation options at Grutas de Tolantongo.',
  url: 'https://tolantongo.com.mx/en/blog/lodging-camping/',
};

const breadcrumbs = [
  { label: 'Blog', href: '/en/blog/' },
  { label: 'Lodging & Camping' },
];
---

<BaseLayout title="Lodging & Camping in Tolantongo — Cabins, Campsite & More" description="Complete lodging guide for Tolantongo: thermal cabins, camping zone, how to book, what to bring, and accommodation comparison." canonical="/en/blog/lodging-camping/" schema={schema} breadcrumbs={breadcrumbs} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Topic: Lodging</span>
        <h1 class="hero__title">Lodging & Camping in Tolantongo</h1>
        <p class="hero__desc">Thermal cabins, camping zone, accommodation options, and everything you need to plan an overnight stay in the canyon.</p>
        <div class="hero__actions">
          <a href="/en/lodging/" class="btn btn--primary btn--lg">See Options</a>
          <a href="/en/prices/" class="btn btn--outline btn--lg">See Prices</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-pozas-termales-puente-colgante.webp" alt="Cabins by the river in Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Lodging & Camping Guides</h2>
        <p>Detailed information to choose where to sleep, what to bring for camping, and how to book ahead of time.</p>
      </div>
      {posts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug.replace(/^en-/, '')}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
              lang="en"
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Lodging guides coming soon. Stay tuned!</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>More about Tolantongo</h2>
      </div>
      <div class="card-grid card-grid--3">
        <a href="/en/blog/travel-guides/" class="service-card">
          <div class="service-card__icon">{'\u{1F4CB}'}</div>
          <h3 class="service-card__title">Travel Guides</h3>
          <p class="service-card__desc">What to bring, how to get there, prices, and planning tips.</p>
        </a>
        <a href="/en/blog/thermal-grottoes/" class="service-card">
          <div class="service-card__icon">{'\u{1F30A}'}</div>
          <h3 class="service-card__title">Thermal Grottoes</h3>
          <p class="service-card__desc">Geology, temperatures, and natural wonders.</p>
        </a>
        <a href="/en/blog/adventure-activities/" class="service-card">
          <div class="service-card__icon">{'\u{1F97E}'}</div>
          <h3 class="service-card__title">Activities</h3>
          <p class="service-card__desc">Hiking, rappelling, and adventure experiences.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
