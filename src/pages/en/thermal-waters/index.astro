import Footer from '../../../components/Footer.astro';
import VideoGallery from '../../../components/VideoGallery.astro';
import { touristAttraction } from '../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Tolantongo Thermal Waters',
    description: 'Natural thermal waters at 36°C year-round at Grutas de Tolantongo, Hidalgo, Mexico.',
    url: 'https://tolantongo.com.mx/en/thermal-waters/',
  }),
];
