---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { place, faqPage } from '../../../i18n/schema';

const schema = [
  place({
    name: 'How to Get to Grutas de Tolantongo',
    description: 'Routes from Mexico City, Pachuca and Queretaro to Grutas de Tolantongo, Hidalgo.',
    url: 'https://tolantongo.com.mx/en/how-to-get-here/',
  }),
  faqPage([
    { question: 'Are there tolls from Mexico City?', answer: 'Yes, the Mexico-Pachuca highway has toll booths (~$80-120 MXN one way). The free road via Teotihuacan avoids tolls but adds 30-45 minutes.' },
    { question: 'Can I get there by motorcycle?', answer: 'Yes, the route is suitable for motorcycles. The mountain road on the final stretch is paved but has sharp curves.' },
    { question: 'Is there direct public transit from Mexico City?', answer: 'There is no direct service. It requires a transfer in Ixmiquilpan + shared van. Total: 4-5 hours by public transit.' },
  ]),
];
---

<BaseLayout lang="en" title="How to Get to Grutas de Tolantongo — From Mexico City, Pachuca & Queretaro" description="How to get to Grutas de Tolantongo: 180 km from Mexico City (3 hrs), routes from Pachuca and Queretaro, bus instructions and GPS. Exact coordinates included." canonical="/en/how-to-get-here/" schema={schema}>
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/en/" class="breadcrumbs__link">Home</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">How to Get Here</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Access instructions</span>
        <h1 class="hero__title">How to get to Grutas de Tolantongo</h1>
        <p class="hero__desc">180 km from Mexico City. Fully paved road. Approximately 2.5 to 3 hours from CDMX.</p>
        <div class="hero__actions">
          <a href="https://maps.app.goo.gl/tolantongo" class="btn btn--primary btn--lg">Open in Google Maps</a>
          <a href="/en/prices/" class="btn btn--outline btn--lg">View prices</a>
        </div>
        <div class="stats-row"><div class="stat"><strong>180 km</strong><span>From Mexico City</span></div><div class="stat"><strong>2.5–3 hrs</strong><span>Estimated time</span></div><div class="stat"><strong>GPS Coord.</strong><span>20.6392, -99.115</span></div></div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-cascada-montana-hidalgo.webp" alt="Mountain road towards Grutas de Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
    </svg>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Main access routes</h2>
        <p>Tolantongo is accessible from several cities. All routes are on paved roads.</p>
      </div>
      <div class="card-grid card-grid--3 animate-on-scroll delay-1">
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-vista-canon-montanas-hidalgo.webp" alt="Route from Mexico City" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Most popular</span>
            <p class="photo-card__title">From Mexico City</p>
            <div style="display:flex;gap:1rem;margin:.5rem 0;flex-wrap:wrap">
              <span style="font-weight:800;color:#1A3A6B">180 km</span>
              <span style="color:#4A5568">2.5 – 3 hours</span>
            </div>
            <ol style="padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.35rem">
              <li>Insurgentes Norte highway → Pachuca</li>
              <li>Pachuca → Actopan → Ixmiquilpan</li>
              <li>Ixmiquilpan → El Alberto → Tolantongo</li>
            </ol>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-cascada-canon-hidalgo.webp" alt="Route from Pachuca" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From Pachuca</span>
            <p class="photo-card__title">From Pachuca, Hidalgo</p>
            <div style="display:flex;gap:1rem;margin:.5rem 0;flex-wrap:wrap">
              <span style="font-weight:800;color:#1A3A6B">90 km</span>
              <span style="color:#4A5568">1.5 hours</span>
            </div>
            <ol style="padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.35rem">
              <li>Pachuca → Actopan via free road</li>
              <li>Actopan → Ixmiquilpan</li>
              <li>Ixmiquilpan → El Cardonal → Tolantongo</li>
            </ol>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-canon-cascada-paisaje.webp" alt="Route from Queretaro" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From Queretaro</span>
            <p class="photo-card__title">From Queretaro</p>
            <div style="display:flex;gap:1rem;margin:.5rem 0;flex-wrap:wrap">
              <span style="font-weight:800;color:#1A3A6B">200 km</span>
              <span style="color:#4A5568">2.5 – 3 hours</span>
            </div>
            <ol style="padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.35rem">
              <li>Queretaro → highway to Pachuca (MEX-45)</li>
              <li>Exit toward Ixmiquilpan</li>
              <li>Ixmiquilpan → El Alberto → Tolantongo</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container animate-on-scroll" style="max-width:860px">
      <h2 style="margin-bottom:1.5rem">By bus from Mexico City</h2>
      <div style="display:flex;flex-direction:column;gap:1rem">
        <div style="display:flex;gap:1.25rem;align-items:flex-start;padding:1.25rem;background:#F2F2F0;border-radius:16px">
          <div style="width:32px;height:32px;border-radius:50%;background:#FEC700;display:flex;align-items:center;justify-content:center;font-weight:900;color:#1A3A6B;flex-shrink:0">1</div>
          <div><p style="font-weight:700;color:#1A3A6B;margin-bottom:.25rem">Terminal Central del Norte (Mexico City)</p><p style="color:#4A5568;font-size:.9rem;margin:0">Take a direct bus to <strong>Ixmiquilpan</strong> (Autobuses del Valle de Mezquital). Duration: ~2.5 hours.</p></div>
        </div>
        <div style="display:flex;gap:1.25rem;align-items:flex-start;padding:1.25rem;background:#F2F2F0;border-radius:16px">
          <div style="width:32px;height:32px;border-radius:50%;background:#FEC700;display:flex;align-items:center;justify-content:center;font-weight:900;color:#1A3A6B;flex-shrink:0">2</div>
          <div><p style="font-weight:700;color:#1A3A6B;margin-bottom:.25rem">Ixmiquilpan bus terminal</p><p style="color:#4A5568;font-size:.9rem;margin:0">Take a <strong>shared van or minibus</strong> headed to El Cardonal or directly to Tolantongo. Duration: 40-50 min.</p></div>
        </div>
        <div style="display:flex;gap:1.25rem;align-items:flex-start;padding:1.25rem;background:#F2F2F0;border-radius:16px">
          <div style="width:32px;height:32px;border-radius:50%;background:#FEC700;display:flex;align-items:center;justify-content:center;font-weight:900;color:#1A3A6B;flex-shrink:0">3</div>
          <div><p style="font-weight:700;color:#1A3A6B;margin-bottom:.25rem">Arrival at Tolantongo</p><p style="color:#4A5568;font-size:.9rem;margin:0">The van drops you off at the entrance. Do not arrive at night. No cell phone signal in the canyon.</p></div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header animate-on-scroll" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Tips for your trip</h2></div>
      <div class="service-cards animate-on-scroll delay-1"><div class="service-card"><div style="font-size:2.5rem">⛽</div><p class="service-card__title">Fill up in Ixmiquilpan</p><p class="service-card__desc">Last town with full gas stations. No fuel service on the road or at the destination.</p></div><div class="service-card"><div style="font-size:2.5rem">💵</div><p class="service-card__title">Withdraw cash beforehand</p><p class="service-card__desc">Cash only. There are ATMs in Ixmiquilpan. No banking services inside the canyon.</p></div><div class="service-card"><div style="font-size:2.5rem">🌅</div><p class="service-card__title">Arrive early on weekends</p><p class="service-card__desc">Limited capacity. The destination can fill up before 10 AM. Arriving before 8 AM is recommended.</p></div><div class="service-card"><div style="font-size:2.5rem">📡</div><p class="service-card__title">Limited cell phone signal</p><p class="service-card__desc">Download offline maps before departing. Write down the destination's phone number in advance.</p></div></div>
    </div>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>This destination awaits you</h2>
        <p>A visual preview of what you'll find on arrival</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-canon-pozas-panoramica-amplia.webp" alt="Panoramic view of the canyon with thermal pools" width="800" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-cascada-montana-hidalgo.webp" alt="Waterfall in the Hidalgo mountains" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-vista-canon-montanas-hidalgo.webp" alt="Canyon and mountain view in Hidalgo" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-cascada-canon-hidalgo.webp" alt="Waterfall in the Hidalgo canyon" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
      </div>
    </div>
  </section>
  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header animate-on-scroll"><h2 id="faq-t">Questions about getting here</h2></div>
      <div class="faq-list animate-on-scroll delay-1"><details><summary>Are there tolls from Mexico City?</summary><div class="faq-answer">Yes, the Mexico-Pachuca highway has toll booths (~$80-120 MXN one way). The free road via Teotihuacan avoids tolls but adds 30-45 minutes.</div></details><details><summary>Can I get there by motorcycle?</summary><div class="faq-answer">Yes, the route is suitable for motorcycles. The mountain road on the final stretch is paved but has sharp curves.</div></details><details><summary>Is there direct public transit from Mexico City?</summary><div class="faq-answer">There is no direct service. It requires a transfer in Ixmiquilpan + shared van. Total: 4-5 hours by public transit.</div></details></div>
    </div>
  </section>
</BaseLayout>
