---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import VideoGallery from '../../../components/VideoGallery.astro';
import { touristAttraction, faqPage } from '../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Grutas de Tolantongo — Grottoes & Formations',
    description: 'Explore the limestone thermal grottoes, tiered pools, thermal river and 800-meter canyon in Hidalgo, Mexico.',
    url: 'https://tolantongo.com.mx/en/grottoes/',
  }),
  faqPage([
    { question: 'Can you swim inside the grottoes?', answer: 'Yes. There is a thermal water channel of 40-80 cm where visitors can bathe. The constant 36°C makes the experience very pleasant even in winter.' },
    { question: 'Do you need special equipment?', answer: 'No. Water shoes with grip, a swimsuit, and a towel are recommended. The surfaces inside the grottoes can be slippery.' },
    { question: 'Are the grottoes lit?', answer: 'There is basic lighting in the main areas. It is recommended to bring a small flashlight to explore deeper sections.' },
  ]),
];
---

<BaseLayout title="The Thermal Grottoes of Tolantongo — Limestone Caves at 36°C" description="Grutas de Tolantongo: natural limestone caves with waters at 36°C (97°F), tiered pools, a 1.5 km thermal river, and an 800 m canyon in Hidalgo, Mexico." canonical="/en/grottoes/" schema={schema} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/en/" class="breadcrumbs__link">🏠 Home</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Grottoes and Pools</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Thermal nature · Hidalgo</span>
        <h1 class="hero__title">The Thermal Grottoes of Tolantongo</h1>
        <p class="hero__desc">Natural limestone caves formed by thermal waters that emerge at 36°C (97°F) from inside the mountain, within the Tolantongo Canyon.</p>
        <div class="hero__actions">
          <a href="/en/prices/" class="btn btn--primary btn--lg">See admission prices</a>
          <a href="/en/how-to-get-here/" class="btn btn--outline btn--lg">How to get here</a>
        </div>
        <div class="stats-row"><div class="stat"><strong>36°C</strong><span>Constant temperature</span></div><div class="stat"><strong>1.5 km</strong><span>Thermal river</span></div><div class="stat"><strong>6</strong><span>Tiered pools</span></div><div class="stat"><strong>800 m</strong><span>Canyon</span></div></div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-cueva-termal-visitantes.webp" alt="Interior of the Tolantongo thermal grottoes with water at 36°C" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
    </svg>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="two-col animate-on-scroll" style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start">
        <div>
          <h2 style="margin-bottom:1.25rem">What makes the Grutas de Tolantongo unique?</h2>
          <p style="margin-bottom:1rem">Grutas de Tolantongo is a system of natural caves formed in limestone by the action of thermal waters that emerge at 36°C (97°F) from inside the mountain. They are located within the Tolantongo Canyon, municipality of Cardonal, Hidalgo, managed by the indigenous Naehnyue community of Ejido El Alberto.</p>
          <p style="margin-bottom:1rem">Unlike conventional water parks, the grottoes are a natural formation without artificial intervention. The thermal water emerges from fractures in the limestone through a geothermal process that maintains the temperature at a constant 36°C year-round.</p>
          <p>The interior features travertine formations, ceilings up to 15 meters high, and a continuous sound of flowing water that defines the sensory experience of the place.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:1rem">
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">🌡️ Geothermal temperature</p><p style="font-size:.9rem;color:#4A5568;margin:0">A constant 36°C year-round from deep springs, with no artificial heating.</p></div>
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">🪨 Natural travertine</p><p style="font-size:.9rem;color:#4A5568;margin:0">Walls and pools of limestone shaped by thermal water over centuries.</p></div>
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">👨‍👩‍👧 Naehnyue Community</p><p style="font-size:.9rem;color:#4A5568;margin:0">Managed by Ejido El Alberto with a limited daily visitor capacity to preserve the ecosystem.</p></div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--gray" aria-labelledby="pc-title">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2 id="pc-title">Explore all the destination's attractions</h2>
        <p>Inside the Tolantongo Canyon you will find four main zones, each with unique characteristics.</p>
      </div>
      <div class="card-grid card-grid--4 animate-on-scroll delay-1"><a href="/en/grottoes/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-cueva-termal-interior-rio.webp" alt="The thermal grottoes" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Most visited</span>
            <p class="photo-card__title">The Thermal Grottoes</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">Limestone tunnels with water at 36°C.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/en/grottoes/tiered-pools/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-pozas-termales-escaleras-naturales.webp" alt="Thermal tiered pools" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Iconic</span>
            <p class="photo-card__title">Tiered Pools</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">Six cascading pools carved into the rock.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/en/grottoes/river/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-rio-turquesa-balneario-natural.webp" alt="Tolantongo thermal river" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">One of a kind in Mexico</span>
            <p class="photo-card__title">Tolantongo River</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">1.5 km of thermal river inside the canyon.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/en/grottoes/canyon/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-canon-verde-panoramica.webp" alt="Tolantongo Canyon" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Spectacular</span>
            <p class="photo-card__title">Tolantongo Canyon</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">800 meters of vertical walls.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a></div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header animate-on-scroll" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Plan your visit to the grottoes</h2></div>
      <div class="service-cards animate-on-scroll delay-1"><div class="service-card"><div style="font-size:2.5rem">🎟️</div><p class="service-card__title">Prices 2026</p><p class="service-card__desc">Admission, cabin, and camping rates.</p><a href="/en/prices/" class="btn">See rates</a></div><div class="service-card"><div style="font-size:2.5rem">🚗</div><p class="service-card__title">How to get here</p><p class="service-card__desc">Routes from Mexico City, Pachuca, and Queretaro.</p><a href="/en/how-to-get-here/" class="btn">See routes</a></div><div class="service-card"><div style="font-size:2.5rem">🏕️</div><p class="service-card__title">Lodging</p><p class="service-card__desc">Cabins and camping inside the canyon.</p><a href="/en/lodging/" class="service-card__cta">See options →</a></div><div class="service-card"><div style="font-size:2.5rem">📋</div><p class="service-card__title">What to bring</p><p class="service-card__desc">Complete packing list for your visit.</p><a href="/en/blog/what-to-bring-to-tolantongo/" class="service-card__cta">See list →</a></div></div>
    </div>
  </section>
  <VideoGallery videoIds={['albercas-drone','cascada-minerales-musgo','cascada-monumental','cascada-termal-minerales','gruta-cascada-gigante']} lang="en" title="Grottoes videos" columns={3} />

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Destination gallery</h2>
        <p>Images of natural formations and thermal waters</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-cueva-termal-formaciones-minerales.webp" alt="Mineral formations inside the thermal cave" width="800" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-canon-verde-panoramica.webp" alt="Panoramic view of Tolantongo green canyon" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-rio-turquesa-balneario-natural.webp" alt="Turquoise river in the natural bathing area" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-escaleras-naturales.webp" alt="Natural stairways between thermal pools" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header animate-on-scroll"><h2 id="faq-t">Questions about the grottoes</h2></div>
      <div class="faq-list animate-on-scroll delay-1"><details><summary>Can you swim inside the grottoes?</summary><div class="faq-answer">Yes. There is a thermal water channel of 40-80 cm where visitors can bathe. The constant 36°C makes the experience very pleasant even in winter.</div></details><details><summary>Do you need special equipment?</summary><div class="faq-answer">No. Water shoes with grip, a swimsuit, and a towel are recommended. The surfaces inside the grottoes can be slippery.</div></details><details><summary>Are the grottoes lit?</summary><div class="faq-answer">There is basic lighting in the main areas. It is recommended to bring a small flashlight to explore deeper sections.</div></details></div>
    </div>
  </section>
</BaseLayout>
