---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { touristAttraction, faqPage } from '../../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Tiered Pools — Grutas de Tolantongo',
    description: '6 natural tiered thermal pools on the canyon hillside with 36°C water.',
    url: 'https://tolantongo.com.mx/en/grottoes/tiered-pools/',
  }),
  faqPage([
    { question: 'How many pools are there in total?', answer: 'There are six main pools arranged in cascade. Each one has different dimensions and depths. There are also several thermal water channels and small pools along the way.' },
    { question: 'Are the pools suitable for children?', answer: 'Yes. There are shallow pools perfect for children. Always with adult supervision. Water shoes are also recommended for the little ones.' },
    { question: 'Is there an extra charge for the pools?', answer: 'No. The tiered pools are included in the general admission price. There is no additional cost.' },
  ]),
];
