---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { touristAttraction, faqPage } from '../../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Tolantongo Canyon',
    description: '800-meter canyon with limestone walls, waterfalls and thermal pools in Hidalgo.',
    url: 'https://tolantongo.com.mx/en/grottoes/canyon/',
  }),
  faqPage([
    { question: 'Can you go hiking in the canyon?', answer: 'Yes. There are maintained trails that ascend the canyon walls to the viewpoints. The trails do not require specialized equipment, but hiking boots and basic physical fitness are recommended.' },
    { question: 'How tall are the canyon walls?', answer: 'The walls of the Tolantongo Canyon reach up to 800 meters at their highest points. Most of the visited area is at the bottom of the canyon.' },
    { question: 'Is the canyon dangerous?', answer: 'The tourist area is maintained and has signage. Dangerous zones are clearly marked. Always respect the signage and stay on the marked trails.' },
  ]),
];
---

<BaseLayout title="Tolantongo Canyon — 800 Meters of Limestone in Hidalgo" description="The Tolantongo Canyon: 800 meters of limestone walls, geothermal springs, panoramic viewpoints, and endemic flora and fauna in Cardonal, Hidalgo." canonical="/en/grottoes/canyon/" schema={schema} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/en/" class="breadcrumbs__link">🏠 Home</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><a href="/en/grottoes/" class="breadcrumbs__link">Grottoes and Pools</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Tolantongo Canyon</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Hidalgo · Spectacular geology</span>
        <h1 class="hero__title">Tolantongo Canyon</h1>
        <p class="hero__desc">An 800-meter canyon carved in limestone over millions of years by geothermal and hydrological activity. The natural setting that makes Tolantongo one of Mexico's most impressive destinations.</p>
        <div class="hero__actions">
          <a href="/en/prices/" class="btn btn--primary btn--lg">See admission prices</a>
          <a href="/en/how-to-get-here/" class="btn btn--outline btn--lg">How to get here</a>
        </div>
        <div class="stats-row"><div class="stat"><strong>800 m</strong><span>Canyon height</span></div><div class="stat"><strong>Limestone</strong><span>Natural formation</span></div><div class="stat"><strong>360° views</strong><span>From viewpoints</span></div><div class="stat"><strong>No artificial elements</strong><span>Pure nature</span></div></div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-canon-cascada-paisaje.webp" alt="Tolantongo Canyon with waterfall and vegetation" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start">
        <div>
          <h2 style="margin-bottom:1.25rem">The geological formation behind Tolantongo</h2>
          <p style="margin-bottom:1rem">The Tolantongo Canyon is a limestone geological formation located in the Sierra Madre Oriental, municipality of Cardonal, Hidalgo. With walls reaching 800 meters in height, the canyon was carved over millions of years by the combination of tectonic activity, water erosion, and geothermal action.</p>
          <p style="margin-bottom:1rem">What makes the Tolantongo Canyon unique compared to others in Mexico is the presence of active geothermal springs in its interior: thermal water at 36°C (97°F) emerges directly from fractures in the rock, creating the grottoes, thermal river, and natural pools that are the main attraction of the destination.</p>
          <p>From the upper viewpoints it is possible to see the complete course of the thermal river and the tiered pools against the backdrop of the canyon wall, a vista that has made the destination go viral on all digital platforms.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:1rem">
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">🌿 Endemic flora</p><p style="font-size:.9rem;color:#4A5568;margin:0">The canyon walls host xerophilous and semi-humid vegetation adapted to the thermal conditions and humidity at the bottom.</p></div>
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">🦅 Canyon birdlife</p><p style="font-size:.9rem;color:#4A5568;margin:0">Golden eagles, falcons, and a wide variety of birds use the canyon's thermal currents to glide.</p></div>
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">📍 Viewpoint access</p><p style="font-size:.9rem;color:#4A5568;margin:0">There are maintained trails leading up to the canyon viewpoints. Hiking boots or sneakers are recommended for the trails.</p></div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Explore the full canyon</h2></div>
      <div class="service-cards"><div class="service-card"><div style="font-size:2.5rem">🌊</div><p class="service-card__title">Thermal Grottoes</p><p class="service-card__desc">The natural caves inside the canyon with water at 36°C.</p><a href="/en/grottoes/" class="btn">See grottoes</a></div><div class="service-card"><div style="font-size:2.5rem">💧</div><p class="service-card__title">Tiered Pools</p><p class="service-card__desc">Six natural pools in cascade on the canyon wall.</p><a href="/en/grottoes/tiered-pools/" class="btn">See pools</a></div><div class="service-card"><div style="font-size:2.5rem">🏞️</div><p class="service-card__title">Thermal River</p><p class="service-card__desc">1.5 km of thermal river inside the canyon with underground stretches.</p><a href="/en/grottoes/river/" class="btn">See river</a></div><div class="service-card"><div style="font-size:2.5rem">🥾</div><p class="service-card__title">Hiking</p><p class="service-card__desc">Trails to the canyon's panoramic viewpoints.</p><a href="/en/activities/hiking/" class="btn">See activities</a></div></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Photo Gallery</h2>
        <p>Discover the breathtaking scenery of the Tolantongo Canyon</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-canon-pozas-panoramica-amplia.webp" alt="Wide panoramic view of the canyon with thermal pools below" width="900" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-canon-vista-soleada.webp" alt="Sunny view of the Tolantongo canyon walls and vegetation" width="600" height="450" loading="lazy">
