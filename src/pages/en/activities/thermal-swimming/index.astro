---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { touristAttraction, faqPage } from '../../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Thermal Swimming — Grutas de Tolantongo',
    description: 'Swim in 36°C thermal waters in the tiered pools and thermal river at Tolantongo.',
    url: 'https://tolantongo.com.mx/en/activities/thermal-swimming/',
  }),
  faqPage([
    { question: 'Is there a depth limit for swimming?', answer: 'In the grottoes the channel is 40–80 cm deep. In the pools it varies between 30 cm and 1.2 m. In the river it can reach 1.5 m in some stretches.' },
    { question: 'Can you swim in winter?', answer: 'Yes. The constant 36°C temperature makes swimming in winter especially pleasant. On cold days the temperature contrast creates mist over the water, a unique visual spectacle.' },
    { question: 'Is it suitable for non-swimmers?', answer: 'Yes. Most areas have manageable depth. The grottoes and the beginning of the river are perfect for those who cannot swim. Always go accompanied.' },
  ]),
];
