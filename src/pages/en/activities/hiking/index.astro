---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import VideoPlayer from '../../../../components/VideoPlayer.astro';
import { touristAttraction, faqPage } from '../../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Hiking at Grutas de Tolantongo',
    description: 'Hiking trails in the Tolantongo canyon with spectacular viewpoints.',
    url: 'https://tolantongo.com.mx/en/activities/hiking/',
  }),
  faqPage([
    { question: 'Are the trails marked?', answer: 'The main trails have basic signage. For the upper trails it is recommended to go accompanied and get directions from destination staff.' },
    { question: 'Can you hike with children?', answer: 'The main trail at the canyon floor is suitable for children. The ascent trails to the viewpoints require some physical fitness and are not recommended for young children.' },
    { question: 'Are hiking guides available?', answer: 'The destination does not offer official hiking guides. The trails are freely accessible and included with general admission.' },
  ]),
];
---

<BaseLayout title="Hiking at Grutas de Tolantongo — 800 m Canyon Viewpoints" description="Hiking at Tolantongo: natural trails to 800 m canyon viewpoints with panoramic views. Included with general admission. Hidalgo, Mexico." canonical="/en/activities/hiking/" schema={schema} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/en/" class="breadcrumbs__link">🏠 Home</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><a href="/en/activities/" class="breadcrumbs__link">Activities</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Hiking at Tolantongo Canyon</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Hiking and nature</span>
        <h1 class="hero__title">Hiking at Tolantongo Canyon</h1>
        <p class="hero__desc">Natural trails that ascend the canyon walls to viewpoints with 360° views over the thermal river, pools and the Sierra Madre Oriental.</p>
        <div class="hero__actions">
          <a href="/en/prices/" class="btn btn--primary btn--lg">See admission prices</a>
          <a href="/en/activities/" class="btn btn--outline btn--lg">See all activities</a>
        </div>
        <div class="stats-row"><div class="stat"><strong>800 m</strong><span>Maximum elevation</span></div><div class="stat"><strong>360° views</strong><span>From viewpoints</span></div><div class="stat"><strong>No special gear</strong><span>Accessible</span></div><div class="stat"><strong>Included</strong><span>With admission</span></div></div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-cascada-sendero-panoramica.webp" alt="Hiking trail with panoramic view at Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem">
        <div>
          <h2 style="margin-bottom:1.25rem">Available trails at the destination</h2>
          <div style="display:flex;flex-direction:column;gap:1rem">
            <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)">
              <p style="font-weight:800;color:#1A3A6B;margin-bottom:.35rem">🟢 Main trail — Easy level</p>
              <p style="font-size:.875rem;color:#4A5568;margin:0">Follows the canyon floor along the thermal river. Distance: ~1.5 km. No significant elevation change. Suitable for all ages.</p>
            </div>
            <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)">
              <p style="font-weight:800;color:#1A3A6B;margin-bottom:.35rem">🟡 Pools trail — Moderate level</p>
              <p style="font-size:.875rem;color:#4A5568;margin:0">Ascends through the tiered pools to the upper pool viewpoint. ~300 m elevation gain. Stone steps available.</p>
            </div>
            <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)">
              <p style="font-weight:800;color:#1A3A6B;margin-bottom:.35rem">🔴 Upper viewpoint trail — Difficult level</p>
              <p style="font-size:.875rem;color:#4A5568;margin:0">Ascends to the viewpoints at the top of the canyon. ~600 m elevation gain. Requires good physical condition and hiking boots.</p>
            </div>
          </div>
        </div>
        <div>
          <h2 style="margin-bottom:1.25rem">Views from the viewpoints</h2>
          <p style="margin-bottom:1rem">The viewpoints at Tolantongo Canyon offer unique perspectives that are impossible to appreciate from the bottom. From the top you can see the complete course of the thermal river, the cascading pattern of the tiered pools and the expanse of the Sierra Madre Oriental.</p>
          <p>The best time for the viewpoints is at sunrise (6–8 AM) when the thermal mist from the river creates a spectacular visual effect from above, or at sunset when warm light illuminates the canyon walls.</p>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Plan your activity at Tolantongo</h2></div>
      <div class="service-cards"><div class="service-card"><div style="font-size:2.5rem">👟</div><p class="service-card__title">Recommended footwear</p><p class="service-card__desc">Grip-sole sneakers for easy trails. Hiking boots for the upper trail.</p><a href="/en/blog/que-llevar-a-tolantongo/" class="service-card__cta">What to bring →</a></div><div class="service-card"><div style="font-size:2.5rem">💧</div><p class="service-card__title">Hydration</p><p class="service-card__desc">Bring enough drinking water. The trails have no drinking water points along the route.</p></div><div class="service-card"><div style="font-size:2.5rem">🌅</div><p class="service-card__title">Best time to climb</p><p class="service-card__desc">Sunrise to see the thermal mist. Avoid climbing during the hottest hours (11 AM – 3 PM).</p></div><div class="service-card"><div style="font-size:2.5rem">🎟️</div><p class="service-card__title">Included with admission</p><p class="service-card__desc">All trails are included in the general admission price at no additional cost.</p><a href="/en/prices/" class="btn">See rates</a></div></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Photo Gallery</h2>
        <p>Discover the hiking trails and canyon views at Tolantongo</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--tall">
          <img src="/media/grutas-tolantongo-cascada-mineral-principal.webp" alt="Main mineral waterfall cascading down the canyon wall" width="600" height="900" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-cascada-sendero-panoramica.webp" alt="Panoramic view of the waterfall from the hiking trail" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-canon-nublado.webp" alt="Thermal pools inside the canyon on a misty cloudy day" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-vista-general-montana.webp" alt="General view of thermal pools with mountains in the background" width="600" height="450" loading="lazy">
        </div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Trail video</h2>
      </div>
      <div class="animate-on-scroll delay-1">
        <VideoPlayer videoId="cascada-mineral-vegetacion" lang="en" />
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header"><h2 id="faq-t">Questions about hiking</h2></div>
      <div class="faq-list"><details><summary>Are the trails marked?</summary><div class="faq-answer">The main trails have basic signage. For the upper trails it is recommended to go accompanied and get directions from destination staff.</div></details><details><summary>Can you hike with children?</summary><div class="faq-answer">The main trail at the canyon floor is suitable for children. The ascent trails to the viewpoints require some physical fitness and are not recommended for young children.</div></details><details><summary>Are hiking guides available?</summary><div class="faq-answer">The destination does not offer official hiking guides. The trails are freely accessible and included with general admission.</div></details></div>
    </div>
  </section>
</BaseLayout>
