---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import { touristAttraction, faqPage } from '../../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Photography at Grutas de Tolantongo',
    description: 'Best spots and times for photography at Grutas de Tolantongo.',
    url: 'https://tolantongo.com.mx/en/activities/photography/',
  }),
  faqPage([
    { question: 'Are drones allowed at Tolantongo?', answer: 'Drone use may be subject to restrictions by the destination. Check directly with the administration before bringing flight equipment.' },
    { question: 'Are there restrictions for commercial photography?', answer: 'Prior permission from the destination\'s administration is required for commercial photo shoots or productions.' },
    { question: 'What is the best time of year to photograph Tolantongo?', answer: 'Winter (December–February) for thermal mist. Spring (March–May) for clear skies and green vegetation. Avoid summer rains for better clarity.' },
  ]),
];
---

<BaseLayout title="Photography at Grutas de Tolantongo — Spots & Best Hours 2026" description="Photography at Tolantongo: best spots, golden hours, recommended settings and tips for photographing thermal grottoes, pools and canyon in Hidalgo." canonical="/en/activities/photography/" schema={schema} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/en/" class="breadcrumbs__link">🏠 Home</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><a href="/en/activities/" class="breadcrumbs__link">Activities</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Photography at Grutas de Tolantongo</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Nature photography</span>
        <h1 class="hero__title">Photography at Grutas de Tolantongo</h1>
        <p class="hero__desc">One of the most spectacular photography destinations in Mexico: 800-meter canyon, thermal river with mist, cascading pools and sun-lit grottoes.</p>
        <div class="hero__actions">
          <a href="/en/prices/" class="btn btn--primary btn--lg">See admission prices</a>
          <a href="/en/activities/" class="btn btn--outline btn--lg">See all activities</a>
        </div>
        <div class="stats-row"><div class="stat"><strong>Viral spot</strong><span>1M+ photos on social</span></div><div class="stat"><strong>Golden hour</strong><span>6–8 AM and 5–7 PM</span></div><div class="stat"><strong>Thermal mist</strong><span>Only in winter</span></div><div class="stat"><strong>No restrictions</strong><span>Cameras allowed</span></div></div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-poza-infinita-mujer-vista-montanas.webp" alt="Photography spot at Tolantongo infinity pools" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="section__header">
        <h2>The best photography spots at the destination</h2>
        <p>Each zone of the destination has unique photographic characteristics. Plan your route based on what you want to capture.</p>
      </div>
      <div class="card-grid card-grid--2" style="gap:1.5rem">
        <div style="background:white;border-radius:20px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08)">
          <div style="background:#1A3A6B;padding:1rem 1.5rem;display:flex;align-items:center;gap:.75rem">
            <span style="font-size:1.5rem">🌊</span>
            <p style="font-weight:800;color:#FEC700;margin:0;font-size:1rem">Inside the Grottoes</p>
          </div>
          <div style="padding:1.5rem">
            <p style="font-size:.9rem;color:#4A5568;margin-bottom:.75rem">The grottoes only receive natural light at certain points. The contrast between illuminated and dark areas creates unique dramatic effects.</p>
            <p style="font-size:.8rem;font-weight:700;color:#1A3A6B;margin-bottom:.25rem">📷 Recommended settings</p>
            <p style="font-size:.8rem;color:#4A5568;margin:0">ISO 1600–3200, aperture f/2.8, slow shutter speed. Use natural light when possible.</p>
          </div>
        </div>
        <div style="background:white;border-radius:20px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08)">
          <div style="background:#1A3A6B;padding:1rem 1.5rem;display:flex;align-items:center;gap:.75rem">
            <span style="font-size:1.5rem">💧</span>
            <p style="font-weight:800;color:#FEC700;margin:0;font-size:1rem">Tiered Pools</p>
          </div>
          <div style="padding:1.5rem">
            <p style="font-size:.9rem;color:#4A5568;margin-bottom:.75rem">The iconic Tolantongo photo. Best from the top looking down with the canyon in the background. Perfect light at sunrise.</p>
            <p style="font-size:.8rem;font-weight:700;color:#1A3A6B;margin-bottom:.25rem">📷 Recommended settings</p>
            <p style="font-size:.8rem;color:#4A5568;margin:0">Wide angle, f/8, ISO 100. Use a polarizer to reduce water reflections.</p>
          </div>
        </div>
        <div style="background:white;border-radius:20px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08)">
          <div style="background:#1A3A6B;padding:1rem 1.5rem;display:flex;align-items:center;gap:.75rem">
            <span style="font-size:1.5rem">🌫️</span>
            <p style="font-weight:800;color:#FEC700;margin:0;font-size:1rem">Thermal river mist</p>
          </div>
          <div style="padding:1.5rem">
            <p style="font-size:.9rem;color:#4A5568;margin-bottom:.75rem">On cold days (November to March) the thermal river generates spectacular mist at sunrise. Only available between 6 and 9 AM.</p>
            <p style="font-size:.8rem;font-weight:700;color:#1A3A6B;margin-bottom:.25rem">📷 Best season</p>
            <p style="font-size:.8rem;color:#4A5568;margin:0">December to February for the densest mist. Arrive right at 6 AM.</p>
          </div>
        </div>
        <div style="background:white;border-radius:20px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08)">
          <div style="background:#1A3A6B;padding:1rem 1.5rem;display:flex;align-items:center;gap:.75rem">
            <span style="font-size:1.5rem">🏔️</span>
            <p style="font-weight:800;color:#FEC700;margin:0;font-size:1rem">Canyon viewpoints</p>
          </div>
          <div style="padding:1.5rem">
            <p style="font-size:.9rem;color:#4A5568;margin-bottom:.75rem">Complete panoramic views of the canyon and river from above. Telephoto to compress perspective or wide angle for the panorama.</p>
            <p style="font-size:.8rem;font-weight:700;color:#1A3A6B;margin-bottom:.25rem">📷 Recommended settings</p>
            <p style="font-size:.8rem;color:#4A5568;margin:0">Golden hour (sunrise/sunset). Tripod for long exposures.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Plan your activity at Tolantongo</h2></div>
      <div class="service-cards"><div class="service-card"><div style="font-size:2.5rem">🕕</div><p class="service-card__title">Arrive at sunrise</p><p class="service-card__desc">6 AM is the best time: fewer visitors, golden light and possible thermal mist in winter.</p></div><div class="service-card"><div style="font-size:2.5rem">💧</div><p class="service-card__title">Protect your gear</p><p class="service-card__desc">A waterproof case is mandatory for your camera or phone. The humid grotto environment can damage unprotected equipment.</p><a href="/en/blog/que-llevar-a-tolantongo/" class="service-card__cta">What to bring →</a></div><div class="service-card"><div style="font-size:2.5rem">📱</div><p class="service-card__title">Your phone works too</p><p class="service-card__desc">The best Tolantongo photographers on Instagram use iPhones or Androids. The place makes the photo, not the equipment.</p></div><div class="service-card"><div style="font-size:2.5rem">🎟️</div><p class="service-card__title">Admission includes everything</p><p class="service-card__desc">There are no restricted photography zones. Access to all spots is included with general admission.</p><a href="/en/prices/" class="btn">See rates</a></div></div>
    </div>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Best shots of the destination</h2>
        <p>Visual inspiration for your photography visit</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-cascada-visitante-sonriente.webp" alt="Smiling visitor posing by the waterfall" width="800" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-dorado-atardecer.webp" alt="Thermal pools at golden sunset" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-atardecer-canon-hidalgo.webp" alt="Sunset in the Hidalgo canyon" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-poza-infinita-mujer-vista-montanas.webp" alt="Woman contemplating mountains from infinity pool" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
      </div>
    </div>
  </section>
  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header"><h2 id="faq-t">Questions about photography</h2></div>
      <div class="faq-list"><details><summary>Are drones allowed at Tolantongo?</summary><div class="faq-answer">Drone use may be subject to restrictions by the destination. Check directly with the administration before bringing flight equipment.</div></details><details><summary>Are there restrictions for commercial photography?</summary><div class="faq-answer">Prior permission from the destination's administration is required for commercial photo shoots or productions.</div></details><details><summary>What is the best time of year to photograph Tolantongo?</summary><div class="faq-answer">Winter (December–February) for thermal mist. Spring (March–May) for clear skies and green vegetation. Avoid summer rains for better clarity.</div></details></div>
    </div>
  </section>
</BaseLayout>
