---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { lodging, faqPage } from '../../../../i18n/schema';

const schema = [
  lodging('LodgingBusiness', {
    name: 'Thermal Cabins — Grutas de Tolantongo',
    description: 'Cabins with thermal water access at Grutas de Tolantongo. Basic, family and premium options.',
    url: 'https://tolantongo.com.mx/en/lodging/cabins/',
  }),
  faqPage([
    { question: 'Do the cabins have heating?', answer: 'The cabins do not have conventional electric heating, but the thermal water in the bathroom keeps the environment warm. It is recommended to bring warm clothing for the night, especially in winter.' },
    { question: 'Is there food service at the destination?', answer: 'Yes, there are food stalls and small restaurants inside the destination. It is also recommended to bring snacks as food prices are higher than in the city.' },
    { question: 'What are the check-in and check-out times?', answer: 'Check-in is generally from 2:00 PM and check-out before 12:00 PM. Confirm with the destination when booking.' },
  ]),
];
---

<BaseLayout title="Thermal Cabins at Grutas de Tolantongo — Basic, Family & Premium" description="Cabins at Grutas de Tolantongo: basic from $900 MXN, family $1,400 MXN and premium $2,200 MXN with private thermal jacuzzi. Grotto access included." canonical="/en/lodging/cabins/" schema={schema} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/en/" class="breadcrumbs__link">🏠 Home</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><a href="/en/lodging/" class="breadcrumbs__link">Lodging</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Thermal Cabins</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Accommodation inside the canyon</span>
        <h1 class="hero__title">Thermal Cabins at Grutas de Tolantongo</h1>
        <p class="hero__desc">Sleep inside the canyon and wake up to the sound of the thermal river. Three categories available, all with their own thermal water.</p>
        <div class="hero__actions">
          <a href="/en/prices/" class="btn btn--primary btn--lg">See cabin prices</a>
          <a href="/en/lodging/camping/" class="btn btn--outline btn--lg">See camping</a>
        </div>

      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-vista-aerea-hotel-pozas.webp" alt="Aerial view of cabins and pools at Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
    </svg>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="section__header">
        <h2>Available cabin types</h2>
        <p>All cabins include unlimited access to grottoes, pools and thermal river during your stay.</p>
      </div>
      <div class="card-grid card-grid--3">
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">🛏️</div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From $900 MXN / night</span>
            <p class="photo-card__title">Basic Cabin</p>
            <ul style="list-style:disc;padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.25rem;margin-top:.5rem">
              <li>Capacity: 2 people</li>
              <li>Queen bed</li>
              <li>Bathroom with thermal water</li>
              <li>Full access to thermal areas</li>
            </ul>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">🏠</div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From $1,400 MXN / night</span>
            <p class="photo-card__title">Family Cabin</p>
            <ul style="list-style:disc;padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.25rem;margin-top:.5rem">
              <li>Capacity: 4 people</li>
              <li>2 double beds</li>
              <li>Private bathroom with thermal water</li>
              <li>Canyon view</li>
              <li>Full access to thermal areas</li>
            </ul>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">⭐</div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From $2,200 MXN / night</span>
            <p class="photo-card__title">Premium Cabin</p>
            <ul style="list-style:disc;padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.25rem;margin-top:.5rem">
              <li>Capacity: 4–6 people</li>
              <li>Private thermal jacuzzi</li>
              <li>Living room and dining area</li>
              <li>Panoramic canyon terrace</li>
              <li>Full access to thermal areas</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Book your cabin</h2></div>
      <div class="service-cards"><div class="service-card"><div style="font-size:2.5rem">📞</div><p class="service-card__title">Phone</p><p class="service-card__desc">Call directly to verify availability and confirm your reservation.</p><p style="font-size:1.2rem;font-weight:900;color:#1A3A6B;margin:.5rem 0">+52 55 6465 0507</p></div><div class="service-card"><div style="font-size:2.5rem">💬</div><p class="service-card__title">WhatsApp</p><p class="service-card__desc">The fastest way to check availability on weekends and peak season.</p><a href="https://wa.me/525564650507" class="btn">Message now</a></div><div class="service-card"><div style="font-size:2.5rem">💵</div><p class="service-card__title">Cash only</p><p class="service-card__desc">No card terminals. Withdraw cash in Ixmiquilpan before arriving at the destination.</p><a href="/en/how-to-get-here/" class="service-card__cta">How to get here →</a></div><div class="service-card"><div style="font-size:2.5rem">📅</div><p class="service-card__title">Book ahead</p><p class="service-card__desc">Premium cabins sell out first. Book at least 2 weeks in advance.</p><a href="/en/prices/" class="service-card__cta">See prices →</a></div></div>
    </div>
  </section>
  <VideoGallery videoIds={['hotel-pozas-aerea','cabana-interior']} lang="en" title="Lodging videos" columns={2} />

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Cabin surroundings</h2>
        <p>The cabins are surrounded by the canyon's natural landscape</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-pozas-termales-detalle-escaleras.webp" alt="Stairway detail between thermal pools" width="800" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-vista-aerea-hotel-pozas.webp" alt="Aerial view of the cabin complex" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-poza-termal-hojas-tropicales.webp" alt="Thermal pool next to tropical vegetation" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-mujer-relax.webp" alt="Visitor relaxing in the thermal pools" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header"><h2 id="faq-t">Questions about cabins</h2></div>
      <div class="faq-list"><details><summary>Do the cabins have heating?</summary><div class="faq-answer">The cabins do not have conventional electric heating, but the thermal water in the bathroom keeps the environment warm. It is recommended to bring warm clothing for the night, especially in winter.</div></details><details><summary>Is there food service at the destination?</summary><div class="faq-answer">Yes, there are food stalls and small restaurants inside the destination. It is also recommended to bring snacks as food prices are higher than in the city.</div></details><details><summary>What are the check-in and check-out times?</summary><div class="faq-answer">Check-in is generally from 2:00 PM and check-out before 12:00 PM. Confirm with the destination when booking.</div></details></div>
    </div>
  </section>
</BaseLayout>
