---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import VideoPlayer from '../../../components/VideoPlayer.astro';
import { lodging, faqPage } from '../../../i18n/schema';

const schema = [
  lodging('LodgingBusiness', {
    name: 'Lodging at Grutas de Tolantongo',
    description: 'Lodging options at Grutas de Tolantongo: thermal cabins and camping inside the canyon.',
    url: 'https://tolantongo.com.mx/en/lodging/',
  }),
  faqPage([
    { question: 'Do the cabins have hot water?', answer: 'Yes, with thermal water from the natural springs. Premium cabins have a private thermal jacuzzi.' },
    { question: 'Can you camp with your own tent?', answer: 'Yes. The camping area costs $250 MXN per night. Tent rental is also available for $350 MXN with a sleeping bag.' },
    { question: 'Does lodging include thermal admission?', answer: 'Yes. All options (cabins and camping) include full access at no additional cost.' },
  ]),
];
---

<BaseLayout title="Lodging at Grutas de Tolantongo — Cabins & Camping 2026" description="Lodging at Grutas de Tolantongo: cabins from $900 MXN, family cabins $1,400 MXN, premium $2,200 MXN and camping $250 MXN. Thermal access included." canonical="/en/lodging/" schema={schema} lang="en">
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/en/" class="breadcrumbs__link">🏠 Home</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Lodging</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Cabins and camping available</span>
        <h1 class="hero__title">Lodging at Grutas de Tolantongo</h1>
        <p class="hero__desc">Stay overnight inside the canyon and enjoy the complete thermal experience. Basic, family, premium cabins and camping available.</p>
        <div class="hero__actions">
          <a href="/en/prices/" class="btn btn--primary btn--lg">See lodging prices</a>
          <a href="/en/contact/" class="btn btn--outline btn--lg">Check availability</a>
        </div>

      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-pozas-termales-puente-colgante.webp" alt="Lodging cabins at Grutas de Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
    </svg>
  </section>
  <section class="section section--gray" aria-labelledby="pc-title">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2 id="pc-title">Available lodging options</h2>
        <p>Three types of cabins and a camping area, all with included access to the thermal areas.</p>
      </div>
      <div class="card-grid card-grid--4 animate-on-scroll delay-1"><a href="/en/lodging/cabins/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-vista-aerea-hotel-pozas.webp" alt="Basic cabins" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From $900 MXN</span>
            <p class="photo-card__title">Basic Cabins</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">For 2 people. Queen bed, bathroom and thermal access.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/en/lodging/cabins/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-pozas-termales-mujer-relax.webp" alt="Family cabins with a view" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From $1,400 MXN</span>
            <p class="photo-card__title">Family Cabins</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">For 4 people. 2 beds, private bathroom, canyon view.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/en/lodging/cabins/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-poza-termal-hojas-tropicales.webp" alt="Premium cabins with thermal jacuzzi" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From $2,200 MXN</span>
            <p class="photo-card__title">Premium Cabins</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">Private thermal jacuzzi, living room, panoramic terrace.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/en/lodging/camping/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-pozas-termales-arboles-relax.webp" alt="Camping area at Tolantongo" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">From $250 MXN</span>
            <p class="photo-card__title">Camping Area</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">Bring your own tent or rent one. Restrooms and water included.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a></div>
    </div>
  </section>
  <section class="section">
    <div class="container animate-on-scroll" style="max-width:860px">
      <h2 style="margin-bottom:1.25rem">Why stay overnight at Tolantongo?</h2>
      <p style="margin-bottom:1rem">Staying inside the canyon allows you to enjoy the waters in the early morning without visitors, watch sunrise with a canyon view and listen to the thermal river during the night. Guests have access to the thermal areas outside regular hours with greater tranquility, especially during peak season.</p>
      <p>All options include full access to grottoes, tiered pools, thermal river and canyon at no additional cost during your stay.</p>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header animate-on-scroll" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Ready to stay at Tolantongo?</h2></div>
      <div class="service-cards animate-on-scroll delay-1"><div class="service-card"><div style="font-size:2.5rem">📞</div><p class="service-card__title">Book by phone</p><p class="service-card__desc">Call directly to verify availability and current rates.</p><p style="font-size:1.2rem;font-weight:900;color:#1A3A6B;margin:.5rem 0">+52 55 6465 0507</p></div><div class="service-card"><div style="font-size:2.5rem">💬</div><p class="service-card__title">WhatsApp</p><p class="service-card__desc">Message us to confirm availability, especially on weekends and holidays.</p><a href="https://wa.me/525564650507" class="btn">Message now</a></div><div class="service-card"><div style="font-size:2.5rem">💵</div><p class="service-card__title">Cash only</p><p class="service-card__desc">Payment is cash only. Withdraw money in Ixmiquilpan before arriving.</p><a href="/en/how-to-get-here/" class="service-card__cta">See directions →</a></div><div class="service-card"><div style="font-size:2.5rem">📅</div><p class="service-card__title">Book in advance</p><p class="service-card__desc">During peak season cabins sell out. Book at least 2 weeks ahead.</p><a href="/en/prices/" class="service-card__cta">See prices →</a></div></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Lodging video</h2>
      </div>
      <div class="animate-on-scroll delay-1">
        <VideoPlayer videoId="hotel-pozas-aerea" lang="en" />
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>The destination in images</h2>
        <p>Discover the facilities and natural surroundings</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-pozas-termales-detalle-turquesa.webp" alt="Turquoise water detail in the thermal pools" width="800" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-vista-aerea-hotel-pozas.webp" alt="Aerial view of the hotel next to the pools" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-puente-colgante.webp" alt="Hanging bridge over the thermal pools" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-poza-termal-hojas-tropicales.webp" alt="Thermal pool surrounded by tropical vegetation" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-arboles-relax.webp" alt="Relaxation area between trees and pools" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header animate-on-scroll"><h2 id="faq-t">Questions about lodging</h2></div>
      <div class="faq-list animate-on-scroll delay-1"><details><summary>Do the cabins have hot water?</summary><div class="faq-answer">Yes, with thermal water from the natural springs. Premium cabins have a private thermal jacuzzi.</div></details><details><summary>Can you camp with your own tent?</summary><div class="faq-answer">Yes. The camping area costs $250 MXN per night. Tent rental is also available for $350 MXN with a sleeping bag.</div></details><details><summary>Does lodging include thermal admission?</summary><div class="faq-answer">Yes. All options (cabins and camping) include full access at no additional cost.</div></details></div>
    </div>
  </section>
</BaseLayout>
