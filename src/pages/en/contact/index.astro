---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { localBusiness } from '../../../i18n/schema';

const schema = [
  localBusiness({
    name: 'Contact — Grutas de Tolantongo',
    description: 'Phone, WhatsApp and email for Grutas de Tolantongo.',
    url: 'https://tolantongo.com.mx/en/contact/',
  }),
];
---

<BaseLayout lang="en" title="Contact — Grutas de Tolantongo · Phone, WhatsApp & Email" description="Contact Grutas de Tolantongo: +52 55 6465 0507, direct WhatsApp and info@grutasdetolantongo.mx. Inquiries about prices, reservations and availability." canonical="/en/contact/" schema={schema}>
  <Header slot="header" lang="en" />
  <Footer slot="footer" lang="en" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/en/" class="breadcrumbs__link">Home</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Contact</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">We are here to help</span>
        <h1 class="hero__title">Contact us</h1>
        <p class="hero__desc">For questions about prices, lodging reservations, availability or any information about your visit to Grutas de Tolantongo.</p>
        <div class="hero__actions">
          <a href="tel:+525564650507" class="btn btn--primary btn--lg">Call now</a>
          <a href="https://wa.me/525564650507" class="btn btn--outline btn--lg">WhatsApp</a>
        </div>

      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-vista-canon-montanas-hidalgo.webp" alt="View of the Tolantongo canyon" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
    </svg>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header animate-on-scroll" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Available contact channels</h2></div>
      <div class="service-cards animate-on-scroll delay-1"><div class="service-card"><div style="font-size:2.5rem">📞</div><p class="service-card__title">Phone</p><p class="service-card__desc">Call directly for quick information about prices, hours and availability.</p><p style="font-size:1.3rem;font-weight:900;color:#1A3A6B;margin:.5rem 0">+52 55 6465 0507</p><p style="font-size:.75rem;color:#1A3A6B;opacity:.8">Monday to Sunday · 6:00 AM – 8:00 PM</p></div><div class="service-card"><div style="font-size:2.5rem">💬</div><p class="service-card__title">WhatsApp</p><p class="service-card__desc">The fastest way to ask about cabin availability and specific questions.</p><a href="https://wa.me/525564650507" class="btn">Message now</a></div><div class="service-card"><div style="font-size:2.5rem">✉️</div><p class="service-card__title">Email</p><p class="service-card__desc">For non-urgent inquiries or for groups and special events.</p><a href="mailto:info@grutasdetolantongo.mx" style="color:#1A3A6B;font-weight:700;font-size:.9rem">info@grutasdetolantongo.mx</a></div><div class="service-card"><div style="font-size:2.5rem">📍</div><p class="service-card__title">Location</p><p class="service-card__desc">El Alberto s/n, Cardonal, Hidalgo, Mexico. 180 km from Mexico City.</p><a href="/en/how-to-get-here/" class="service-card__cta">How to get here →</a></div></div>
    </div>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Visit Tolantongo</h2>
        <p>A unique natural destination in Hidalgo, Mexico</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-pozas-termales-panoramica-amplia.webp" alt="Panoramic view of the Tolantongo thermal pools" width="800" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-cascada-puente-visitantes.webp" alt="Pedestrian bridge with visitors next to waterfall" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-rio-turquesa-balneario-natural.webp" alt="Turquoise river in the natural bathing area" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-vista-canon-montanas-hidalgo.webp" alt="Canyon and mountain view in Hidalgo" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
      </div>
    </div>
  </section>
  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header animate-on-scroll"><h2 id="faq-t">Contact FAQ</h2></div>
      <div class="faq-list animate-on-scroll delay-1"><details><summary>What is the best way to book a cabin?</summary><div class="faq-answer">The most direct way is to call by phone or WhatsApp. There is no online booking system currently. Confirm availability and pay in cash upon arrival.</div></details><details><summary>What time can I call?</summary><div class="faq-answer">The destination operates from 6:00 AM to 8:00 PM every day. For advance reservations you can try calling during any business hours.</div></details><details><summary>Do you have social media accounts?</summary><div class="faq-answer">Yes. You can find updated information, photos and closure notices on the destination's social media accounts on Facebook and Instagram.</div></details></div>
    </div>
  </section>
</BaseLayout>
