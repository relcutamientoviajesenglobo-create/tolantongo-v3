---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import VideoGallery from '../../../components/VideoGallery.astro';
import { touristAttraction, faqPage } from '../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Cañón de Tolantongo',
    description: 'Cañón de 800 metros con paredes de piedra caliza, cascadas y pozas termales en Hidalgo.',
    url: 'https://tolantongo.com.mx/grutas/canon/',
  }),
  faqPage([
    { question: '¿Se puede hacer senderismo en el cañón?', answer: 'Sí. Hay senderos habilitados que ascienden por las paredes del cañón hacia los miradores. Los senderos no requieren equipo especializado pero se recomienda calzado de montaña y condición física básica.' },
    { question: '¿Qué altura tienen las paredes del cañón?', answer: 'Las paredes del Cañón de Tolantongo alcanzan hasta 800 metros en sus puntos más altos. La mayor parte del área visitada está en el fondo del cañón.' },
    { question: '¿Es peligroso el cañón?', answer: 'El área turística está habilitada y señalizada. Las zonas peligrosas están delimitadas. Siempre respetar las señalizaciones y no salirse de los senderos marcados.' },
  ]),
];
---

<BaseLayout title="Cañón de Tolantongo — 800 Metros de Roca Caliza en Hidalgo" description="El Cañón de Tolantongo: 800 metros de paredes de roca caliza, manantiales geotérmicos, miradores panorámicos y flora y fauna endémica en Cardonal, Hidalgo." canonical="/grutas/canon/" schema={schema}>
  <Header slot="header" />
  <Footer slot="footer" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">🏠 Inicio</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><a href="/grutas/" class="breadcrumbs__link">Grutas y Albercas</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Cañón de Tolantongo</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Hidalgo · Geología espectacular</span>
        <h1 class="hero__title">Cañón de Tolantongo</h1>
        <p class="hero__desc">Un cañón de 800 metros de altura tallado en roca caliza por millones de años de actividad geotérmica e hídrica. El marco natural que hace de Tolantongo uno de los destinos más impresionantes de México.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver precios de entrada</a>
          <a href="/como-llegar/" class="btn btn--outline btn--lg">Cómo llegar</a>
        </div>
        <div class="stats-row"><div class="stat"><strong>800 m</strong><span>Altura del cañón</span></div><div class="stat"><strong>Roca caliza</strong><span>Formación natural</span></div><div class="stat"><strong>Vistas 360°</strong><span>Desde miradores</span></div><div class="stat"><strong>Sin artificios</strong><span>Naturaleza pura</span></div></div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-canon-cascada-paisaje.webp" alt="Cañón de Tolantongo con cascada y vegetación" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start">
        <div>
          <h2 style="margin-bottom:1.25rem">La formación geológica detrás de Tolantongo</h2>
          <p style="margin-bottom:1rem">El Cañón de Tolantongo es una formación geológica de roca caliza ubicada en la Sierra Madre Oriental, municipio de Cardonal, Hidalgo. Con paredes que alcanzan los 800 metros de altura, el cañón fue tallado durante millones de años por la combinación de actividad tectónica, erosión hídrica y acción geotérmica.</p>
          <p style="margin-bottom:1rem">Lo que hace único al cañón de Tolantongo respecto a otros de México es la presencia de manantiales geotérmicos activos en su interior: el agua termal a 36°C emerge directamente desde fracturas en la roca, creando las grutas, el río termal y las albercas naturales que son el atractivo principal del destino.</p>
          <p>Desde los miradores superiores es posible ver el trazado completo del río termal y las albercas escalonadas contra el fondo de la pared del cañón, una vista que ha hecho viral al destino en todas las plataformas digitales.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:1rem">
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">🌿 Flora endémica</p><p style="font-size:.9rem;color:#4A5568;margin:0">Las paredes del cañón albergan vegetación xerófila y semihúmeda adaptada a las condiciones termales y la humedad del fondo.</p></div>
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">🦅 Avifauna del cañón</p><p style="font-size:.9rem;color:#4A5568;margin:0">Águilas reales, halcones y una gran variedad de aves utilizan las corrientes térmicas del cañón para planear.</p></div>
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">📍 Acceso a los miradores</p><p style="font-size:.9rem;color:#4A5568;margin:0">Hay senderos habilitados que suben a los miradores del cañón. Calzado de montaña o tenis recomendable para los senderos.</p></div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Explora el cañón completo</h2></div>
      <div class="service-cards"><div class="service-card"><div style="font-size:2.5rem">🌊</div><p class="service-card__title">Grutas Termales</p><p class="service-card__desc">Las cuevas naturales dentro del cañón con agua a 36°C.</p><a href="/grutas/" class="btn">Ver grutas</a></div><div class="service-card"><div style="font-size:2.5rem">💧</div><p class="service-card__title">Albercas Escalonadas</p><p class="service-card__desc">Seis piscinas naturales en cascada sobre la pared del cañón.</p><a href="/grutas/albercas-escalonadas/" class="btn">Ver albercas</a></div><div class="service-card"><div style="font-size:2.5rem">🏞️</div><p class="service-card__title">Río Termal</p><p class="service-card__desc">1.5 km de río termal dentro del cañón con tramos subterráneos.</p><a href="/grutas/rio/" class="btn">Ver río</a></div><div class="service-card"><div style="font-size:2.5rem">🥾</div><p class="service-card__title">Senderismo</p><p class="service-card__desc">Senderos hacia los miradores panorámicos del cañón.</p><a href="/actividades/senderismo/" class="btn">Ver actividades</a></div></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Galería fotográfica</h2>
        <p>Descubre la belleza del cañón de Tolantongo desde diferentes perspectivas</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-canon-pozas-panoramica-amplia.webp" alt="Vista panorámica amplia del cañón con pozas termales de Tolantongo" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-canon-vista-soleada.webp" alt="Vista soleada del cañón de Tolantongo con vegetación" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-cascada-mineral-aerea.webp" alt="Vista aérea de la cascada mineral en el cañón de Tolantongo" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-cascada-mineral-bruma.webp" alt="Cascada mineral con bruma en el cañón de Tolantongo" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-cascada-principal-vista-baja.webp" alt="Cascada principal del cañón vista desde abajo" width="600" height="450" loading="lazy">
        </div>
      </div>
    </div>
  </section>
  <VideoGallery videoIds={['cascada-roca-closeup','cascada-monumental','canon-puente-panoramica']} lang="es" title="Videos del cañón" columns={3} />

  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header"><h2 id="faq-t">Preguntas sobre el cañón</h2></div>
      <div class="faq-list"><details><summary>¿Se puede hacer senderismo en el cañón?</summary><div class="faq-answer">Sí. Hay senderos habilitados que ascienden por las paredes del cañón hacia los miradores. Los senderos no requieren equipo especializado pero se recomienda calzado de montaña y condición física básica.</div></details><details><summary>¿Qué altura tienen las paredes del cañón?</summary><div class="faq-answer">Las paredes del Cañón de Tolantongo alcanzan hasta 800 metros en sus puntos más altos. La mayor parte del área visitada está en el fondo del cañón.</div></details><details><summary>¿Es peligroso el cañón?</summary><div class="faq-answer">El área turística está habilitada y señalizada. Las zonas peligrosas están delimitadas. Siempre respetar las señalizaciones y no salirse de los senderos marcados.</div></details></div>
    </div>
  </section>
</BaseLayout>
