        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-poza-infinita-pareja-canon.webp" alt="Pareja disfrutando la poza infinita con vista al cañón" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-poza-infinita-redonda.webp" alt="Poza infinita redonda natural en las terrazas de Tolantongo" width="600" height="450" loading="lazy">
