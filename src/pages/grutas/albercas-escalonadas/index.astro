---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import VideoGallery from '../../../components/VideoGallery.astro';
import { touristAttraction, faqPage } from '../../../i18n/schema';

const schema = [
  touristAttraction({
    name: 'Albercas Escalonadas — Grutas de Tolantongo',
    description: '6 albercas termales naturales escalonadas en la ladera del cañón con agua a 36°C.',
    url: 'https://tolantongo.com.mx/grutas/albercas-escalonadas/',
  }),
  faqPage([
    { question: '¿Cuántas albercas hay en total?', answer: 'Son seis albercas principales dispuestas en cascada. Cada una tiene dimensiones y profundidades diferentes. Además hay varios pozos y canales de agua termal en el trayecto.' },
    { question: '¿Las albercas son aptas para niños?', answer: 'Sí. Hay albercas de poca profundidad perfectas para niños. Siempre con supervisión adulta. Se recomienda zapatos acuáticos también para los pequeños.' },
    { question: '¿Hay que pagar extra por las albercas?', answer: 'No. Las albercas escalonadas están incluidas en el precio de entrada general. No hay costo adicional.' },
  ]),
];
---

<BaseLayout title="Albercas Escalonadas de Tolantongo — 6 Piscinas Naturales a 36°C" description="Las albercas escalonadas de Tolantongo: 6 piscinas de roca caliza en cascada con agua termal a 36°C y vistas al cañón de 800 m. Incluidas en la entrada general." canonical="/grutas/albercas-escalonadas/" schema={schema}>
  <Header slot="header" />
  <Footer slot="footer" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">🏠 Inicio</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><a href="/grutas/" class="breadcrumbs__link">Grutas y Albercas</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Albercas Escalonadas</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Hidalgo · Destino termal</span>
        <h1 class="hero__title">Albercas Escalonadas de Tolantongo</h1>
        <p class="hero__desc">Seis albercas naturales excavadas en roca caliza viva, dispuestas en cascada a lo largo del cañón. Agua termal a 36°C con vistas panorámicas al cañón de 800 metros.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver precios de entrada</a>
          <a href="/como-llegar/" class="btn btn--outline btn--lg">Cómo llegar</a>
        </div>
        <div class="stats-row"><div class="stat"><strong>6 albercas</strong><span>En cascada</span></div><div class="stat"><strong>36°C</strong><span>Todo el año</span></div><div class="stat"><strong>Roca viva</strong><span>Sin artificios</span></div><div class="stat"><strong>800 m</strong><span>Vista al cañón</span></div></div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-pozas-termales-terrazas-naturales.webp" alt="Albercas escalonadas termales de Tolantongo con vista al cañón" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start">
        <div>
          <h2 style="margin-bottom:1.25rem">¿Cómo son las albercas escalonadas?</h2>
          <p style="margin-bottom:1rem">Las albercas escalonadas de Tolantongo son seis piscinas naturales dispuestas en cascada descendente sobre la pared del cañón. Cada alberca se desborda hacia la siguiente, creando un flujo continuo de agua termal a 36°C que recorre la formación rocosa de arriba hacia abajo.</p>
          <p style="margin-bottom:1rem">Las albercas están excavadas directamente en la roca caliza: sus bordes, fondo y paredes son 100% naturales. El carbonato de calcio disuelto en el agua termal va depositando capas de travertino que modifican lentamente la forma de cada piscina, haciendo que ninguna alberca sea igual a la siguiente.</p>
          <p>La alberca más alta tiene vistas directas al cañón de 800 metros y es la más fotografiada del destino. El acceso entre albercas es por escaleras de roca y senderos habilitados.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:1rem">
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">💧 Agua en movimiento constante</p><p style="font-size:.9rem;color:#4A5568;margin:0">Cada alberca se desborda hacia la siguiente, garantizando circulación continua y agua siempre limpia.</p></div>
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">📐 Profundidades variadas</p><p style="font-size:.9rem;color:#4A5568;margin:0">Desde piscinas de 30 cm para niños hasta albercas de 1.2 m de profundidad para adultos.</p></div>
          <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><p style="font-weight:800;color:#1A3A6B;margin-bottom:.5rem">📸 Spot fotográfico icónico</p><p style="font-size:.9rem;color:#4A5568;margin:0">La vista desde la alberca superior con el cañón de fondo es la imagen más viral de Tolantongo.</p></div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Planea tu visita a las albercas</h2></div>
      <div class="service-cards"><div class="service-card"><div style="font-size:2.5rem">🎟️</div><p class="service-card__title">Precios 2026</p><p class="service-card__desc">Entrada adulto $220 MXN incluye acceso a albercas, grutas, río y cañón.</p><a href="/precios/" class="btn">Ver tarifas</a></div><div class="service-card"><div style="font-size:2.5rem">🕐</div><p class="service-card__title">Mejor horario</p><p class="service-card__desc">Entre semana por la mañana temprano. Los fines de semana se llenan antes de las 10 am.</p><a href="/como-llegar/" class="service-card__cta">Cómo llegar →</a></div><div class="service-card"><div style="font-size:2.5rem">👟</div><p class="service-card__title">Calzado recomendado</p><p class="service-card__desc">Zapatos acuáticos con agarre. Las escaleras de roca entre albercas pueden ser resbaladizas.</p><a href="/blog/que-llevar-a-tolantongo/" class="service-card__cta">Qué llevar →</a></div><div class="service-card"><div style="font-size:2.5rem">📸</div><p class="service-card__title">Mejor vista fotográfica</p><p class="service-card__desc">La alberca más alta al atardecer, con el cañón como fondo. Lleva protección waterproof para tu cámara.</p></div></div>
    </div>
  </section>
