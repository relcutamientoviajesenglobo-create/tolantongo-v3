---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.silo === 'cultura-region' && (p.data.lang === 'es' || !p.data.lang))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cultura y Región de Tolantongo',
  description: 'Historia, cultura Hñähñu, gastronomía regional y turismo sustentable en Cardonal y la Sierra Gorda de Hidalgo.',
  url: 'https://tolantongo.com.mx/blog/cultura-region/',
};

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Cultura y Región' },
];
---

<BaseLayout title="Cultura y Región — Historia, Gastronomía y Cardonal, Hidalgo" description="Descubre la historia de las Grutas de Tolantongo, la cultura Hñähñu, gastronomía de la Sierra Gorda y el municipio de Cardonal, Hidalgo." canonical="/blog/cultura-region/" schema={schema} breadcrumbs={breadcrumbs}>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Silo: Cultura</span>
        <h1 class="hero__title">Cultura y región de Tolantongo</h1>
        <p class="hero__desc">La historia, la cultura Hñähñu, la gastronomía de la Sierra Gorda y el contexto que hace de Tolantongo mucho más que un destino termal.</p>
        <div class="hero__actions">
          <a href="/blog/guias-viaje/" class="btn btn--primary btn--lg">Guías de viaje</a>
          <a href="/blog/" class="btn btn--outline btn--lg">Todo el blog</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-atardecer-canon-hidalgo.webp" alt="Vista del Cañón de Tolantongo en la Sierra Gorda de Hidalgo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Historia, cultura y región</h2>
        <p>Artículos sobre el contexto histórico, cultural y geográfico que rodea a las Grutas de Tolantongo.</p>
      </div>
      {posts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Próximamente artículos de cultura y región. ¡Vuelve pronto!</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Explora otros temas</h2>
      </div>
      <div class="card-grid card-grid--3">
        <a href="/blog/grutas-termales/" class="service-card">
          <div class="service-card__icon">🌊</div>
          <h3 class="service-card__title">Grutas Termales</h3>
          <p class="service-card__desc">Geología, temperaturas y naturaleza del cañón.</p>
        </a>
        <a href="/blog/guias-viaje/" class="service-card">
          <div class="service-card__icon">📋</div>
          <h3 class="service-card__title">Guías de Viaje</h3>
          <p class="service-card__desc">Todo para planear tu visita a Tolantongo.</p>
        </a>
        <a href="/blog/hospedaje-camping/" class="service-card">
          <div class="service-card__icon">🏕️</div>
          <h3 class="service-card__title">Hospedaje y Camping</h3>
          <p class="service-card__desc">Cabañas, campamento y dónde dormir.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
