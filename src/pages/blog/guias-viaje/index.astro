---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.silo === 'guias-viaje' && (p.data.lang === 'es' || !p.data.lang))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Guías de Viaje a Tolantongo',
  description: 'Guías prácticas para planear tu visita a las Grutas de Tolantongo: qué llevar, cómo llegar, precios, mejor época y consejos.',
  url: 'https://tolantongo.com.mx/blog/guias-viaje/',
};

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Guías de Viaje' },
];
---

<BaseLayout title="Guías de Viaje a Tolantongo — Consejos y Planificación 2026" description="Todo para planear tu visita a Tolantongo: qué llevar, cómo llegar, precios actualizados, mejor época, seguridad y consejos prácticos de viajeros reales." canonical="/blog/guias-viaje/" schema={schema} breadcrumbs={breadcrumbs}>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Silo: Guías de Viaje</span>
        <h1 class="hero__title">Guías de viaje a Tolantongo</h1>
        <p class="hero__desc">Información práctica, actualizada y basada en experiencia real para que planees la visita perfecta a las Grutas de Tolantongo.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver precios 2026</a>
          <a href="/como-llegar/" class="btn btn--outline btn--lg">Cómo llegar</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-cascada-termal-visitante.webp" alt="Viajeros en las Grutas de Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Guías y artículos de viaje</h2>
        <p>Toda la información que necesitas para preparar tu visita a Tolantongo, escrita por quienes conocen cada rincón del destino.</p>
      </div>
      {posts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Próximamente nuevas guías de viaje. ¡Vuelve pronto!</p>
      )}
    </div>
  </section>

  <!-- Contextual bridges to other silos -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Explora más sobre Tolantongo</h2>
      </div>
      <div class="card-grid card-grid--3">
        <a href="/blog/grutas-termales/" class="service-card">
          <div class="service-card__icon">🌊</div>
          <h3 class="service-card__title">Grutas Termales</h3>
          <p class="service-card__desc">Descubre la geología, temperaturas y maravillas naturales del cañón.</p>
        </a>
        <a href="/blog/actividades-aventura/" class="service-card">
          <div class="service-card__icon">🥾</div>
          <h3 class="service-card__title">Actividades y Aventura</h3>
          <p class="service-card__desc">Senderismo, rappel, fotografía y natación termal.</p>
        </a>
        <a href="/blog/hospedaje-camping/" class="service-card">
          <div class="service-card__icon">🏕️</div>
          <h3 class="service-card__title">Hospedaje y Camping</h3>
          <p class="service-card__desc">Cabañas, campamento y opciones de alojamiento.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
