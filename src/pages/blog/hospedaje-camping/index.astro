---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.silo === 'hospedaje-camping' && (p.data.lang === 'es' || !p.data.lang))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Hospedaje y Camping en Tolantongo',
  description: 'Guías de cabañas, camping, reservaciones y opciones de alojamiento en las Grutas de Tolantongo.',
  url: 'https://tolantongo.com.mx/blog/hospedaje-camping/',
};

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Hospedaje y Camping' },
];
---

<BaseLayout title="Hospedaje y Camping en Tolantongo — Cabañas, Campamento y Más" description="Guía completa de hospedaje en Tolantongo: cabañas termales, zona de camping, cómo reservar, qué llevar y comparativa de opciones de alojamiento." canonical="/blog/hospedaje-camping/" schema={schema} breadcrumbs={breadcrumbs}>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Silo: Hospedaje</span>
        <h1 class="hero__title">Hospedaje y camping en Tolantongo</h1>
        <p class="hero__desc">Cabañas termales, zona de campamento, opciones de alojamiento y todo lo que necesitas para quedarte a dormir en el cañón.</p>
        <div class="hero__actions">
          <a href="/hospedaje/" class="btn btn--primary btn--lg">Ver opciones</a>
          <a href="/precios/" class="btn btn--outline btn--lg">Ver precios</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-pozas-termales-puente-colgante.webp" alt="Cabañas junto al río en Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Guías de hospedaje y campamento</h2>
        <p>Información detallada para elegir dónde dormir, qué llevar al camping y cómo reservar con anticipación.</p>
      </div>
      {posts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Próximamente guías de hospedaje. ¡Vuelve pronto!</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Más sobre Tolantongo</h2>
      </div>
      <div class="card-grid card-grid--3">
        <a href="/blog/guias-viaje/" class="service-card">
          <div class="service-card__icon">📋</div>
          <h3 class="service-card__title">Guías de Viaje</h3>
          <p class="service-card__desc">Qué llevar, cómo llegar, precios y planificación.</p>
        </a>
        <a href="/blog/grutas-termales/" class="service-card">
          <div class="service-card__icon">🌊</div>
          <h3 class="service-card__title">Grutas Termales</h3>
          <p class="service-card__desc">Geología, temperaturas y maravillas naturales.</p>
        </a>
        <a href="/blog/actividades-aventura/" class="service-card">
          <div class="service-card__icon">🥾</div>
          <h3 class="service-card__title">Actividades</h3>
          <p class="service-card__desc">Senderismo, rappel y experiencias de aventura.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
