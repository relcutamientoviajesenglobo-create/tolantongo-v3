---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.silo === 'actividades-aventura' && (p.data.lang === 'es' || !p.data.lang))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Actividades y Aventura en Tolantongo',
  description: 'Guías de senderismo, rappel, natación termal, fotografía y todas las actividades que puedes disfrutar en las Grutas de Tolantongo.',
  url: 'https://tolantongo.com.mx/blog/actividades-aventura/',
};

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Actividades y Aventura' },
];
---

<BaseLayout title="Actividades y Aventura en Tolantongo — Senderismo, Rappel y Más" description="Guías completas de senderismo, rappel, natación termal, fotografía y todas las actividades de aventura en las Grutas de Tolantongo." canonical="/blog/actividades-aventura/" schema={schema} breadcrumbs={breadcrumbs}>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Silo: Actividades</span>
        <h1 class="hero__title">Actividades y aventura en Tolantongo</h1>
        <p class="hero__desc">Senderismo, rappel, natación termal, fotografía y todas las experiencias que puedes vivir en el cañón más impresionante de Hidalgo.</p>
        <div class="hero__actions">
          <a href="/actividades/" class="btn btn--primary btn--lg">Ver actividades</a>
          <a href="/blog/guias-viaje/" class="btn btn--outline btn--lg">Guías de viaje</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-cascada-sendero-visitante.webp" alt="Senderismo en el Cañón de Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Artículos de actividades y aventura</h2>
        <p>Guías detalladas para cada actividad, escritas por guías locales certificados que conocen el terreno.</p>
      </div>
      {posts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Próximamente guías de actividades. ¡Vuelve pronto!</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Explora más temas</h2>
      </div>
      <div class="card-grid card-grid--3">
        <a href="/blog/grutas-termales/" class="service-card">
          <div class="service-card__icon">🌊</div>
          <h3 class="service-card__title">Grutas Termales</h3>
          <p class="service-card__desc">Geología, temperaturas y formaciones naturales.</p>
        </a>
        <a href="/blog/hospedaje-camping/" class="service-card">
          <div class="service-card__icon">🏕️</div>
          <h3 class="service-card__title">Hospedaje y Camping</h3>
          <p class="service-card__desc">Cabañas, campamento y dónde dormir.</p>
        </a>
        <a href="/blog/guias-viaje/" class="service-card">
          <div class="service-card__icon">📋</div>
          <h3 class="service-card__title">Guías de Viaje</h3>
          <p class="service-card__desc">Qué llevar, cómo llegar, precios y más.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
