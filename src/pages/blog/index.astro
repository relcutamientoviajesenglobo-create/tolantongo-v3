---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'es' || !p.data.lang)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const silos = [
  { id: 'all', label: 'Todos', icon: '📚', href: '/blog/' },
  { id: 'guias-viaje', label: 'Guías de viaje', icon: '📋', href: '/blog/guias-viaje/' },
  { id: 'grutas-termales', label: 'Grutas termales', icon: '🌊', href: '/blog/grutas-termales/' },
  { id: 'actividades-aventura', label: 'Actividades', icon: '🥾', href: '/blog/actividades-aventura/' },
  { id: 'hospedaje-camping', label: 'Hospedaje', icon: '🏕️', href: '/blog/hospedaje-camping/' },
  { id: 'cultura-region', label: 'Cultura', icon: '🏛️', href: '/blog/cultura-region/' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog Grutas de Tolantongo',
  description: 'Guías de viaje, consejos prácticos y todo lo que necesitas saber para visitar las Grutas de Tolantongo.',
  url: 'https://tolantongo.com.mx/blog/',
};

const breadcrumbs = [
  { label: 'Blog' },
];
---

<BaseLayout title="Blog Grutas de Tolantongo — Guías de Viaje y Consejos 2026" description="Guías de viaje, consejos prácticos y todo lo que necesitas saber para visitar las Grutas de Tolantongo en 2026. Precios, qué llevar, cómo llegar y más." canonical="/blog/" schema={schema} breadcrumbs={breadcrumbs}>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B">
      <svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/>
      </svg>
    </div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Guías y consejos para visitantes</span>
        <h1 class="hero__title">Blog Grutas de Tolantongo</h1>
        <p class="hero__desc">Guías prácticas, consejos de viaje y todo lo que necesitas saber para planear tu visita perfecta a las Grutas de Tolantongo.</p>
        <div class="hero__actions">
          <a href="/blog/guias-viaje/" class="btn btn--primary btn--lg">Guías de viaje</a>
          <a href="/precios/" class="btn btn--outline btn--lg">Ver precios</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-cascada-aerea-selva.webp" alt="Paisaje natural de las Grutas de Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
  </section>

  <!-- Silo Navigation -->
  <section class="section" style="padding-top:2rem;padding-bottom:0">
    <div class="container">
      <nav class="blog-silo-nav" aria-label="Filtrar por tema">
        {silos.map(silo => (
          <a
            href={silo.href}
            class={`blog-silo-nav__item ${silo.id === 'all' ? 'blog-silo-nav__item--active' : ''}`}
          >
            <span aria-hidden="true">{silo.icon}</span> {silo.label}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- All Posts -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Todos los artículos</h2>
        <p>{allPosts.length} {allPosts.length === 1 ? 'artículo publicado' : 'artículos publicados'}</p>
      </div>
      {allPosts.length > 0 ? (
        <div class="card-grid card-grid--3 animate-on-scroll delay-1">
          {allPosts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--mc-text-muted);padding:3rem 0">Próximamente nuevos artículos. ¡Vuelve pronto!</p>
      )}
    </div>
  </section>

  <!-- Explore Silos -->
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Explora por tema</h2>
        <p>Encuentra exactamente lo que necesitas para tu visita a Tolantongo.</p>
      </div>
      <div class="card-grid card-grid--3 animate-on-scroll delay-1">
        <a href="/blog/guias-viaje/" class="service-card">
          <div class="service-card__icon">📋</div>
          <h3 class="service-card__title">Guías de viaje</h3>
          <p class="service-card__desc">Qué llevar, cómo llegar, precios, mejor época y consejos prácticos.</p>
        </a>
        <a href="/blog/grutas-termales/" class="service-card">
          <div class="service-card__icon">🌊</div>
          <h3 class="service-card__title">Grutas termales</h3>
          <p class="service-card__desc">Geología, temperaturas, albercas escalonadas y formaciones naturales.</p>
        </a>
        <a href="/blog/actividades-aventura/" class="service-card">
          <div class="service-card__icon">🥾</div>
          <h3 class="service-card__title">Actividades y aventura</h3>
          <p class="service-card__desc">Senderismo, rappel, natación termal y fotografía.</p>
        </a>
        <a href="/blog/hospedaje-camping/" class="service-card">
          <div class="service-card__icon">🏕️</div>
          <h3 class="service-card__title">Hospedaje y camping</h3>
          <p class="service-card__desc">Cabañas, campamento, cómo reservar y comparativas.</p>
        </a>
        <a href="/blog/cultura-region/" class="service-card">
          <div class="service-card__icon">🏛️</div>
          <h3 class="service-card__title">Cultura y región</h3>
          <p class="service-card__desc">Historia, cultura Hñähñu, gastronomía y Cardonal.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
