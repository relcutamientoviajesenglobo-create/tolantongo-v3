---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import { lodging, faqPage } from '../../i18n/schema';

const schema = [
  lodging('LodgingBusiness', {
    name: 'Hospedaje en Grutas de Tolantongo',
    description: 'Opciones de hospedaje en Grutas de Tolantongo: cabañas termales y zona de acampado dentro del cañón.',
    url: 'https://tolantongo.com.mx/hospedaje/',
  }),
  faqPage([
    { question: '¿Las cabañas tienen agua caliente?', answer: 'Sí, con agua termal proveniente de los propios manantiales. Las Premium tienen jacuzzi termal privado.' },
    { question: '¿Se puede acampar con tienda propia?', answer: 'Sí. El área de campamento cuesta $250 MXN por noche. También hay renta de tiendas por $350 MXN con sleeping bag.' },
    { question: '¿El hospedaje incluye la entrada termal?', answer: 'Sí. Todas las opciones (cabañas y campamento) incluyen acceso completo sin costo adicional.' },
  ]),
];
---

<BaseLayout title="Hospedaje en Grutas de Tolantongo — Cabañas y Campamento 2026" description="Hospedaje Grutas de Tolantongo: cabañas desde $900 MXN, familiares $1,400 MXN, premium $2,200 MXN y campamento $250 MXN. Acceso termal incluido." canonical="/hospedaje/" schema={schema}>
  <Header slot="header" />
  <Footer slot="footer" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">🏠 Inicio</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Hospedaje</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Cabañas y campamento disponibles</span>
        <h1 class="hero__title">Hospedaje en las Grutas de Tolantongo</h1>
        <p class="hero__desc">Quédate a dormir dentro del cañón y vive la experiencia termal completa. Cabañas básicas, familiares, premium y campamento.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver precios de hospedaje</a>
          <a href="/contacto/" class="btn btn--outline btn--lg">Consultar disponibilidad</a>
        </div>
        
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-pozas-termales-puente-colgante.webp" alt="Cabañas de hospedaje en Grutas de Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
    </svg>
  </section>
  <section class="section section--gray" aria-labelledby="pc-title">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2 id="pc-title">Opciones de hospedaje disponibles</h2>
        <p>Tres tipos de cabaña y área de campamento, todas con acceso incluido a las áreas termales.</p>
      </div>
      <div class="card-grid card-grid--4 animate-on-scroll delay-1"><a href="/hospedaje/cabanas/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-vista-aerea-hotel-pozas.webp" alt="Cabañas básicas" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Desde $900 MXN</span>
            <p class="photo-card__title">Cabañas Básicas</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">Para 2 personas. Cama matrimonial, baño y acceso termal.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/hospedaje/cabanas/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-pozas-termales-mujer-relax.webp" alt="Cabañas familiares con vista" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Desde $1,400 MXN</span>
            <p class="photo-card__title">Cabañas Familiares</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">Para 4 personas. 2 camas, baño privado, vista al cañón.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/hospedaje/cabanas/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-poza-termal-hojas-tropicales.webp" alt="Cabañas premium con jacuzzi termal" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Desde $2,200 MXN</span>
            <p class="photo-card__title">Cabañas Premium</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">Jacuzzi termal privado, sala, terraza panorámica.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a><a href="/hospedaje/camping/" class="photo-card">
          <div class="photo-card__img"><img src="/media/grutas-tolantongo-pozas-termales-arboles-relax.webp" alt="Área de campamento en Tolantongo" width="400" height="300" loading="lazy"></div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Desde $250 MXN</span>
            <p class="photo-card__title">Área de Campamento</p>
            <p style="font-size:.875rem;color:#4A5568;margin-bottom:.5rem">Tienda propia o renta. Sanitarios y agua incluidos.</p>
            <div class="photo-card__arrow"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          </div>
        </a></div>
    </div>
  </section>
  <section class="section">
    <div class="container animate-on-scroll" style="max-width:860px">
      <h2 style="margin-bottom:1.25rem">¿Por qué quedarse a dormir en Tolantongo?</h2>
      <p style="margin-bottom:1rem">Hospedarse dentro del cañón permite disfrutar las aguas en la madrugada sin visitantes, ver amanecer con vista al cañón y escuchar el río termal durante la noche. Los huéspedes tienen acceso a las áreas termales fuera del horario regular con mayor tranquilidad, especialmente en temporada alta.</p>
      <p>Todas las opciones incluyen acceso completo a grutas, albercas escalonadas, río termal y cañón sin costo adicional durante la estadía.</p>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header animate-on-scroll" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">¿Listo para quedarte en Tolantongo?</h2></div>
      <div class="service-cards animate-on-scroll delay-1"><div class="service-card"><div style="font-size:2.5rem">📞</div><p class="service-card__title">Reserva por teléfono</p><p class="service-card__desc">Llama directamente para verificar disponibilidad y tarifas vigentes.</p><p style="font-size:1.2rem;font-weight:900;color:#1A3A6B;margin:.5rem 0">+52 55 6465 0507</p></div><div class="service-card"><div style="font-size:2.5rem">💬</div><p class="service-card__title">WhatsApp</p><p class="service-card__desc">Escríbenos para confirmar disponibilidad, especialmente en fines de semana y puentes.</p><a href="https://wa.me/525564650507" class="btn">Escribir ahora</a></div><div class="service-card"><div style="font-size:2.5rem">💵</div><p class="service-card__title">Solo efectivo</p><p class="service-card__desc">El pago es únicamente en efectivo. Retira dinero en Ixmiquilpan antes de llegar.</p><a href="/como-llegar/" class="service-card__cta">Ver instrucciones →</a></div><div class="service-card"><div style="font-size:2.5rem">📅</div><p class="service-card__title">Reserva con anticipación</p><p class="service-card__desc">En temporada alta las cabañas se agotan. Reservar al menos 2 semanas antes.</p><a href="/precios/" class="service-card__cta">Ver precios →</a></div></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Video del hospedaje</h2>
      </div>
      <div class="animate-on-scroll delay-1">
        <VideoPlayer videoId="hotel-pozas-aerea" lang="es" />
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>El destino en imágenes</h2>
        <p>Conoce las instalaciones y el entorno natural</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-pozas-termales-detalle-turquesa.webp" alt="Detalle del agua turquesa en las pozas termales" width="800" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-vista-aerea-hotel-pozas.webp" alt="Vista aérea del hotel junto a las pozas" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-puente-colgante.webp" alt="Puente colgante sobre las pozas termales" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-poza-termal-hojas-tropicales.webp" alt="Poza termal rodeada de vegetación tropical" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-arboles-relax.webp" alt="Área de descanso entre árboles y pozas" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header animate-on-scroll"><h2 id="faq-t">Preguntas sobre hospedaje</h2></div>
      <div class="faq-list animate-on-scroll delay-1"><details><summary>¿Las cabañas tienen agua caliente?</summary><div class="faq-answer">Sí, con agua termal proveniente de los propios manantiales. Las Premium tienen jacuzzi termal privado.</div></details><details><summary>¿Se puede acampar con tienda propia?</summary><div class="faq-answer">Sí. El área de campamento cuesta $250 MXN por noche. También hay renta de tiendas por $350 MXN con sleeping bag.</div></details><details><summary>¿El hospedaje incluye la entrada termal?</summary><div class="faq-answer">Sí. Todas las opciones (cabañas y campamento) incluyen acceso completo sin costo adicional.</div></details></div>
    </div>
  </section>
</BaseLayout>
