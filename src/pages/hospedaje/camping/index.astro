---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { lodging, faqPage } from '../../../i18n/schema';

const schema = [
  lodging('Campground', {
    name: 'Campamento — Grutas de Tolantongo',
    description: 'Acampa dentro del cañón termal de Tolantongo desde $250 MXN por noche.',
    url: 'https://tolantongo.com.mx/hospedaje/camping/',
  }),
  faqPage([
    { question: '¿Se puede hacer fogata?', answer: 'No se permiten fogatas dentro del área de campamento por seguridad y preservación del entorno natural.' },
    { question: '¿Hay áreas de estacionamiento cerca del campamento?', answer: 'Sí, el estacionamiento vigilado ($60 MXN) está dentro del destino y a poca distancia del área de campamento.' },
    { question: '¿Se permiten mascotas?', answer: 'Las políticas sobre mascotas pueden variar. Se recomienda consultar directamente con el destino antes de llevar mascotas.' },
  ]),
];
---

<BaseLayout title="Campamento en Grutas de Tolantongo — Acampa Dentro del Cañón Termal" description="Campamento Grutas de Tolantongo desde $250 MXN por noche. Tienda propia o renta. Acceso a aguas termales incluido. La experiencia más única del destino." canonical="/hospedaje/camping/" schema={schema}>
  <Header slot="header" />
  <Footer slot="footer" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">🏠 Inicio</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><a href="/hospedaje/" class="breadcrumbs__link">Hospedaje</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Campamento</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Camping dentro del cañón</span>
        <h1 class="hero__title">Campamento en Grutas de Tolantongo</h1>
        <p class="hero__desc">Acampa dentro del cañón de Tolantongo y disfruta las aguas termales de noche. La opción más económica para quedarse en el destino.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver precios de campamento</a>
          <a href="/hospedaje/cabanas/" class="btn btn--outline btn--lg">Ver cabañas</a>
        </div>
        
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-pozas-termales-arboles-relax.webp" alt="Área de camping con árboles junto a pozas termales" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
    </svg>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="section__header">
        <h2>¿Qué incluye el área de campamento?</h2>
        <p>El campamento de Tolantongo es una de las experiencias más únicas de México: dormir al aire libre con el sonido del río termal.</p>
      </div>
      <div class="card-grid card-grid--4">
        <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><div style="font-size:2rem;margin-bottom:.5rem">💧</div><p style="font-weight:800;color:#1A3A6B;margin-bottom:.35rem">Acceso termal</p><p style="font-size:.875rem;color:#4A5568;margin:0">Acceso ilimitado a grutas, albercas y río termal durante tu estadía.</p></div>
        <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><div style="font-size:2rem;margin-bottom:.5rem">🚿</div><p style="font-weight:800;color:#1A3A6B;margin-bottom:.35rem">Sanitarios y agua</p><p style="font-size:.875rem;color:#4A5568;margin:0">Instalaciones sanitarias y agua potable disponibles en el área de campamento.</p></div>
        <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><div style="font-size:2rem;margin-bottom:.5rem">⛺</div><p style="font-weight:800;color:#1A3A6B;margin-bottom:.35rem">Tienda propia o renta</p><p style="font-size:.875rem;color:#4A5568;margin:0">Puedes traer tu tienda ($250 MXN) o rentar una con sleeping bag ($350 MXN).</p></div>
        <div style="background:white;border-radius:16px;padding:1.5rem;box-shadow:0 2px 8px rgba(0,0,0,.06)"><div style="font-size:2rem;margin-bottom:.5rem">🌙</div><p style="font-weight:800;color:#1A3A6B;margin-bottom:.35rem">Experiencia nocturna</p><p style="font-size:.875rem;color:#4A5568;margin:0">Acceso a las albercas por la noche cuando no hay visitantes de día.</p></div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Prepárate para acampar</h2></div>
      <div class="service-cards"><div class="service-card"><div style="font-size:2.5rem">🎒</div><p class="service-card__title">Qué llevar para acampar</p><p class="service-card__desc">Sleeping bag o cobija, ropa abrigadora para la noche, linterna, zapatos acuáticos, efectivo y snacks.</p><a href="/blog/que-llevar-a-tolantongo/" class="service-card__cta">Ver lista completa →</a></div><div class="service-card"><div style="font-size:2.5rem">🌡️</div><p class="service-card__title">Temperatura nocturna</p><p class="service-card__desc">En invierno las noches pueden bajar de 10°C. Llevar ropa abrigadora es indispensable aunque el agua esté a 36°C.</p></div><div class="service-card"><div style="font-size:2.5rem">💵</div><p class="service-card__title">Solo efectivo</p><p class="service-card__desc">El pago de campamento es en efectivo. Retira en Ixmiquilpan antes de llegar.</p><a href="/como-llegar/" class="service-card__cta">Cómo llegar →</a></div><div class="service-card"><div style="font-size:2.5rem">📅</div><p class="service-card__title">Sin reserva previa</p><p class="service-card__desc">El campamento generalmente no requiere reserva previa. Se paga al llegar según disponibilidad. En puentes llega temprano.</p></div></div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Galería fotográfica</h2>
        <p>La experiencia de acampar en el cañón termal de Tolantongo</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-pozas-termales-vista-superior-puente.webp" alt="Vista superior del puente colgante sobre las pozas termales de Tolantongo" width="600" height="450" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header"><h2 id="faq-t">Preguntas sobre el campamento</h2></div>
      <div class="faq-list"><details><summary>¿Se puede hacer fogata?</summary><div class="faq-answer">No se permiten fogatas dentro del área de campamento por seguridad y preservación del entorno natural.</div></details><details><summary>¿Hay áreas de estacionamiento cerca del campamento?</summary><div class="faq-answer">Sí, el estacionamiento vigilado ($60 MXN) está dentro del destino y a poca distancia del área de campamento.</div></details><details><summary>¿Se permiten mascotas?</summary><div class="faq-answer">Las políticas sobre mascotas pueden variar. Se recomienda consultar directamente con el destino antes de llevar mascotas.</div></details></div>
    </div>
  </section>
</BaseLayout>
