---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import VideoGallery from '../../../components/VideoGallery.astro';
import { lodging, faqPage } from '../../../i18n/schema';

const schema = [
  lodging('LodgingBusiness', {
    name: 'Cabañas Termales — Grutas de Tolantongo',
    description: 'Cabañas con acceso a aguas termales en Grutas de Tolantongo. Básica, familiar y premium.',
    url: 'https://tolantongo.com.mx/hospedaje/cabanas/',
  }),
  faqPage([
    { question: '¿Las cabañas tienen calefacción?', answer: 'Las cabañas no tienen calefacción eléctrica convencional, pero el agua termal del baño mantiene el ambiente cálido. Se recomienda llevar ropa abrigadora para la noche, especialmente en invierno.' },
    { question: '¿Hay servicio de comida en el destino?', answer: 'Sí, hay fondas y puestos de comida dentro del destino. Se recomienda también llevar snacks y botanas ya que los precios de comida son más elevados que en la ciudad.' },
    { question: '¿Cuál es el horario de check-in y check-out?', answer: 'El check-in es generalmente a partir de las 2:00 pm y el check-out antes de las 12:00 pm. Confirmar con el destino al momento de reservar.' },
  ]),
];
---

<BaseLayout title="Cabañas Termales en Grutas de Tolantongo — Básicas, Familiares y Premium" description="Cabañas en Grutas de Tolantongo: básicas desde $900 MXN, familiares $1,400 MXN y premium $2,200 MXN con jacuzzi termal privado. Acceso a grutas incluido." canonical="/hospedaje/cabanas/" schema={schema}>
  <Header slot="header" />
  <Footer slot="footer" />
<div class="breadcrumbs"><div class="container"><ol class="breadcrumbs__list"><li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">🏠 Inicio</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><a href="/hospedaje/" class="breadcrumbs__link">Hospedaje</a></li><li class="breadcrumbs__item"><span class="breadcrumbs__sep">›</span><span class="breadcrumbs__current">Cabañas Termales</span></li></ol></div></div>
  <section class="hero">
    <div style="position:absolute;top:0;right:0;opacity:.25;pointer-events:none;color:#1A3A6B"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--blue">Alojamiento dentro del cañón</span>
        <h1 class="hero__title">Cabañas Termales en Grutas de Tolantongo</h1>
        <p class="hero__desc">Duerme dentro del cañón y despierta con el sonido del río termal. Tres categorías disponibles, todas con agua termal propia.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver precios de cabañas</a>
          <a href="/hospedaje/camping/" class="btn btn--outline btn--lg">Ver campamento</a>
        </div>
        
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="/media/grutas-tolantongo-vista-aerea-hotel-pozas.webp" alt="Vista aérea de cabañas y pozas en Tolantongo" width="600" height="400" loading="eager" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit">
        </div>
      </div>
    </div>
    </svg>
  </section>
  <section class="section section--gray">
    <div class="container">
      <div class="section__header">
        <h2>Tipos de cabaña disponibles</h2>
        <p>Todas las cabañas incluyen acceso ilimitado a grutas, albercas y río termal durante la estadía.</p>
      </div>
      <div class="card-grid card-grid--3">
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">🛏️</div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Desde $900 MXN / noche</span>
            <p class="photo-card__title">Cabaña Básica</p>
            <ul style="list-style:disc;padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.25rem;margin-top:.5rem">
              <li>Capacidad: 2 personas</li>
              <li>Cama matrimonial</li>
              <li>Baño con agua termal</li>
              <li>Acceso completo a áreas termales</li>
            </ul>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">🏠</div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Desde $1,400 MXN / noche</span>
            <p class="photo-card__title">Cabaña Familiar</p>
            <ul style="list-style:disc;padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.25rem;margin-top:.5rem">
              <li>Capacidad: 4 personas</li>
              <li>2 camas dobles</li>
              <li>Baño privado con agua termal</li>
              <li>Vista al cañón</li>
              <li>Acceso completo a áreas termales</li>
            </ul>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">⭐</div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Desde $2,200 MXN / noche</span>
            <p class="photo-card__title">Cabaña Premium</p>
            <ul style="list-style:disc;padding-left:1.25rem;color:#4A5568;font-size:.875rem;display:flex;flex-direction:column;gap:.25rem;margin-top:.5rem">
              <li>Capacidad: 4–6 personas</li>
              <li>Jacuzzi termal privado</li>
              <li>Sala y comedor</li>
              <li>Terraza panorámica al cañón</li>
              <li>Acceso completo a áreas termales</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--blue bg-blue" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.18;pointer-events:none;color:#FEC700"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.12;pointer-events:none;color:#FEC700;transform:rotate(180deg)"><svg viewBox="0 0 168 176" width="180" height="188" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M167.701 117.179C161.987 83.6731 119.483 70.9796 119.483 70.9796C119.483 70.9796 147.681 65.0139 148.945 39.3199C149.095 36.2593 147.409 33.3998 144.629 32.1104C120.769 21.0441 107.081 36.8409 107.081 36.8409C107.081 36.8409 115.377 14.4881 104.488 2.44813C102.708 0.480145 99.9804-0.3702 97.3723 0.149701C76.5705 4.29422 66.716 30.5874 66.716 30.5874C66.716 30.5874 54.6599 13.6554 33.9347 18.5254C31.5355 19.0894 29.5343 20.7504 28.5575 23.0092C23.3852 34.9977 28.8677 47.2066 40.1003 57.7162C41.4618 58.991 43.2408 60.445 44.7466 61.6316C46.013 62.6289 45.6281 64.635 44.078 65.0962C42.1731 65.6631 39.8736 66.3475 38.0128 66.9026C26.0282 70.4773 7.31171 79.0733 0.480605 98.4256C-0.148067 100.206 0.102731 102.179 1.19889 103.713C13.4092 120.793 40.9705 122.642 63.952 101.005C63.952 101.005 33.7208 154.096 81.7728 174.647C83.8736 175.546 86.2793 175.46 88.3029 174.396C125.518 154.813 105.439 108.345 105.439 108.345C105.439 108.345 130.307 140.147 163.367 125.421C166.538 124.008 168.282 120.592 167.7 117.177L167.701 117.179Z" fill="currentColor"/></svg></div>
    <div class="container">
      <div class="section__header" style="margin-bottom:2.5rem"><h2 style="color:#FEC700">Reserva tu cabaña</h2></div>
      <div class="service-cards"><div class="service-card"><div style="font-size:2.5rem">📞</div><p class="service-card__title">Teléfono</p><p class="service-card__desc">Llama directamente para verificar disponibilidad y confirmar tu reserva.</p><p style="font-size:1.2rem;font-weight:900;color:#1A3A6B;margin:.5rem 0">+52 55 6465 0507</p></div><div class="service-card"><div style="font-size:2.5rem">💬</div><p class="service-card__title">WhatsApp</p><p class="service-card__desc">El medio más rápido para verificar disponibilidad en fines de semana y temporada alta.</p><a href="https://wa.me/525564650507" class="btn">Escribir ahora</a></div><div class="service-card"><div style="font-size:2.5rem">💵</div><p class="service-card__title">Solo efectivo</p><p class="service-card__desc">Sin terminales bancarias. Retira en Ixmiquilpan antes de llegar al destino.</p><a href="/como-llegar/" class="service-card__cta">Cómo llegar →</a></div><div class="service-card"><div style="font-size:2.5rem">📅</div><p class="service-card__title">Anticipa tu reserva</p><p class="service-card__desc">Las cabañas premium se agotan primero. Reserva con 2 semanas mínimo de anticipación.</p><a href="/precios/" class="service-card__cta">Ver precios →</a></div></div>
    </div>
  </section>
  <VideoGallery videoIds={['hotel-pozas-aerea','cabana-interior']} lang="es" title="Videos del hospedaje" columns={2} />

  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Entorno de las cabañas</h2>
        <p>Las cabañas están rodeadas del paisaje natural del cañón</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="/media/grutas-tolantongo-pozas-termales-detalle-escaleras.webp" alt="Detalle de escaleras entre las pozas termales" width="800" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-vista-aerea-hotel-pozas.webp" alt="Vista aérea del complejo de cabañas" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-poza-termal-hojas-tropicales.webp" alt="Poza termal junto a vegetación tropical" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
        <div class="photo-gallery__item">
          <img src="/media/grutas-tolantongo-pozas-termales-mujer-relax.webp" alt="Visitante relajándose en las pozas termales" width="400" height="300" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px">
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="faq-t">
    <div class="container">
      <div class="section__header"><h2 id="faq-t">Preguntas sobre cabañas</h2></div>
      <div class="faq-list"><details><summary>¿Las cabañas tienen calefacción?</summary><div class="faq-answer">Las cabañas no tienen calefacción eléctrica convencional, pero el agua termal del baño mantiene el ambiente cálido. Se recomienda llevar ropa abrigadora para la noche, especialmente en invierno.</div></details><details><summary>¿Hay servicio de comida en el destino?</summary><div class="faq-answer">Sí, hay fondas y puestos de comida dentro del destino. Se recomienda también llevar snacks y botanas ya que los precios de comida son más elevados que en la ciudad.</div></details><details><summary>¿Cuál es el horario de check-in y check-out?</summary><div class="faq-answer">El check-in es generalmente a partir de las 2:00 pm y el check-out antes de las 12:00 pm. Confirmar con el destino al momento de reservar.</div></details></div>
    </div>
  </section>
</BaseLayout>
